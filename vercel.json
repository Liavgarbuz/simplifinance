// BUDGET ENGINE  (single source of truth — all math here, no duplication)
// ─────────────────────────────────────────────────────────────────────────────
// MECE expense categories — Mutually Exclusive, Collectively Exhaustive
// Every dollar of spending belongs to exactly ONE category
export const EXPENSE_CATS = [
  { id: "housing",       label: "Housing",         hint: "Rent/mortgage, property tax, HOA, renter's insurance, maintenance" },
  { id: "utilities",     label: "Utilities",        hint: "Electric, gas, water, internet, phone" },
  { id: "food",          label: "Food & Dining",    hint: "Groceries, restaurants, coffee, delivery" },
  { id: "transport",     label: "Transportation",   hint: "Car payment, gas, insurance, parking, public transit, rideshare" },
  { id: "healthcare",    label: "Healthcare",       hint: "Insurance premiums (after-tax), copays, prescriptions, dental, vision" },
  { id: "insurance",     label: "Insurance (other)", hint: "Life insurance, disability — health insurance goes in Healthcare" },
  { id: "childcare",     label: "Child & Family",   hint: "Daycare, tuition, child activities, pet expenses" },
  { id: "personal",      label: "Personal Care",    hint: "Haircuts, gym, clothing, toiletries" },
  { id: "entertainment", label: "Entertainment",    hint: "Streaming, hobbies, concerts, books, travel & vacations" },
  { id: "subscriptions", label: "Subscriptions",    hint: "Software, news, memberships not covered elsewhere" },
  { id: "savings_goal",  label: "Savings Goals",    hint: "Non-retirement savings goals (e.g. home down payment, vacation fund)" },
  { id: "giving",        label: "Giving",           hint: "Charitable donations, gifts" },
  { id: "other",         label: "Other",            hint: "Anything that doesn't fit above" },
];

function calcBudget(d) {
  // ── Step 1: Gross income
  const w2 = d.incomes.filter(i => i.type === "w2").reduce((s, i) => s + num(i.amount), 0) + num(d.bonus);
  const se = d.incomes.filter(i => i.type === "self").reduce((s, i) => s + num(i.amount), 0);
  const passive = d.incomes.filter(i => !["w2","self"].includes(i.type)).reduce((s, i) => s + num(i.amount), 0);
  const gross = w2 + se + passive;
  // ── Step 2: Above-the-line deductions → AGI
  const pre401k = num(d.retirement.trad401k) * 12;         // pre-tax; reduces taxable income
  const tradIRA = num(d.retirement.tradIRA) * 12;           // deductible IRA
  const hsaDed = num(d.retirement.hsa) * 12;               // HSA
  const seDed = se * 0.5;                                   // SE tax deduction (50% of SE tax)
  const slIntDed = Math.min(num(d.deductions?.studentLoanInt || 0), 2500);
  const agi = Math.max(0, gross - pre401k - tradIRA - hsaDed - seDed - slIntDed);
  // ── Step 3: Taxable income
  const stdDed = STD_DED[d.filingStatus] || STD_DED.single;
  const itemDed = d.itemize
    ? (num(d.deductions?.mortgage||0) + Math.min(num(d.deductions?.salt||0),10000) + num(d.deductions?.charitable||0) + Math.max(0,num(d.deductions?.medical||0)-agi*0.075) + num(d.deductions?.other||0))
    : 0;
  const ded = d.itemize ? Math.max(stdDed, itemDed) : stdDed;
  const credits = Object.values(d.credits || {}).reduce((s, v) => s + num(v), 0);
  const taxable = Math.max(0, agi - ded);
  // ── Step 4: Federal income tax (ordinary income brackets)
  const fedTax = calcFedTax(taxable, d.filingStatus);
  // ── Step 5: FICA
  const fica = calcFICA(w2 + se * 0.9235, d.filingStatus);
  // ── Step 6: State tax (on AGI)
  const stateTax = agi * num(d.stateRate) / 100;
  // ── Step 7: Apply credits
  const totalTax = Math.max(0, fedTax + fica.total + stateTax - credits);
  // ── Step 8: Net income
  const netAnnual = gross - totalTax;
  // ── Step 9: Cash outflows
  const retMonthly = Object.values(d.retirement).reduce((s, v) => s + num(v), 0);
  const expMonthly = d.expenses.reduce((s, e) => s + num(e.amount), 0);
  const debtPayments = d.liabilities.reduce((s, l) => s + num(l.payment), 0);
  // ── Step 10: Free cash flow / savings
  // Savings = Net Income - Expenses - Retirement Contributions - Debt Payments
  // Note: Roth 401k/IRA come out of net (after-tax), traditional comes from pre-tax (already deducted above)
  const rothContribs = (num(d.retirement.roth401k) + num(d.retirement.rothIRA)) * 12;
  const totalOutflows = (expMonthly + retMonthly) * 12 + debtPayments * 12;
  const annualSavings = netAnnual - totalOutflows;
  const savingsRate = gross > 0 ? Math.max(0, annualSavings) / gross : 0;
  const marginal = getMarginal(taxable, d.filingStatus);
  const effective = gross > 0 ? totalTax / gross : 0;
  return {
    w2, se, passive, gross, pre401k, tradIRA, hsaDed, seDed, slIntDed,
    agi, stdDed, itemDed, ded, credits, taxable, fedTax, fica, stateTax, totalTax,
    netAnnual, retMonthly, expMonthly, debtPayments, annualSavings, savingsRate,
    marginal, effective, rothContribs,
  };
}

// ─────────────────────────────────────────────────────────────────────────────
// INFLATION-ADJUSTED NET WORTH PROJECTION ENGINE
// ─────────────────────────────────────────────────────────────────────────────
// Returns year-by-year projection with nominal AND real values
// Incorporates: portfolio growth, savings, milestones (one-time costs + monthly spend changes),
// liability paydown, and optional inflation adjustment
//
// Formula for each year n:
//   portfolio(n) = portfolio(n-1) × (1 + portfolioRate) + annualContribution
//   liabilities(n) = liabilities(n-1) × (1 + weightedDebtRate/12)^12 - totalDebtPayments×12
//   netWorth(n) = portfolio(n) + cash - liabilities(n) + cumulativeSavings(n)
//   realNetWorth(n) = netWorth(n) / (1 + inflationRate)^n
function buildProjection({ budget, d, prices, inflRate, years = 35 }) {
  const allH = d.accounts.flatMap(a => a.holdings);
  const getPrice = h => prices[h.ticker?.toUpperCase()]?.price || num(h.price);
  const totPort = allH.reduce((s, h) => s + num(h.shares) * getPrice(h), 0);
  const wRet = totPort > 0
    ? allH.reduce((s, h) => { const mv = num(h.shares) * getPrice(h); return s + (mv / totPort) * num(h.expRet); }, 0)
    : 7;
  const portRate = wRet / 100;
  const cash = num(d.checkingBal) + num(d.savingsBal) + num(d.emergencyFund);
  const initLiab = d.liabilities.reduce((s, l) => s + num(l.balance), 0);
  const baseMonthlySavings = budget.annualSavings / 12;
  const curYear = new Date().getFullYear();

  const rows = [];
  let portVal = totPort;
  let liabVal = initLiab;
  let cumulativeLumpCosts = 0;

  for (let i = 0; i <= years; i++) {
    const yr = curYear + i;
    // Milestones active this year
    const newMilestones = d.timeline.filter(m => Number(m.year) === yr);
    const lumpCost = newMilestones.reduce((s, m) => s + num(m.cost), 0);
    // Cumulative monthly delta from all milestones that have occurred
    const activeMilestones = d.timeline.filter(m => Number(m.year) <= yr);
    const cumMonthlyDelta = activeMilestones.reduce((s, m) => s + num(m.monthlyDelta), 0);
    const effectiveMonthlySavings = baseMonthlySavings + cumMonthlyDelta;
    const effectiveAnnualSavings = effectiveMonthlySavings * 12;

    if (i > 0) {
      // Portfolio grows + new savings added
      portVal = portVal * (1 + portRate) + Math.max(0, effectiveAnnualSavings);
      // Liability paydown (monthly compounding)
      const monthlyRate = d.liabilities.length > 0
        ? d.liabilities.reduce((s, l) => s + num(l.rate) / 100 / 12, 0) / Math.max(d.liabilities.length, 1)
        : 0;
      const totalPayments = d.liabilities.reduce((s, l) => s + num(l.payment), 0) * 12;
      liabVal = Math.max(0, liabVal * Math.pow(1 + monthlyRate, 12) - totalPayments);
      // One-time costs reduce portfolio
      portVal = Math.max(0, portVal - lumpCost);
      cumulativeLumpCosts += lumpCost;
    }

    const nominalNW = portVal + cash - liabVal;
    const realNW = real(nominalNW, inflRate, i);
    rows.push({
      year: yr,
      age: d.age + i,
      nominalNW,
      realNW,
      portVal,
      liabVal,
      lumpCost,
      effectiveMonthlySavings,
      newMilestones,
      activeMilestones,
    });
  }
  return rows;
}

// ─────────────────────────────────────────────────────────────────────────────
// STORAGE — localStorage with optional Supabase cloud sync
// Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in .env for cloud persistence
// Without those env vars the app works fine using localStorage only
// ─────────────────────────────────────────────────────────────────────────────
const STORE = "sf_v4";
const SB_URL = import.meta.env.VITE_SUPABASE_URL;
const SB_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY;
const USE_CLOUD = !!(SB_URL && SB_KEY);

const loadP = () => { try { return JSON.parse(localStorage.getItem(STORE) || "{}"); } catch { return {}; } };
const saveP = p => {
  localStorage.setItem(STORE, JSON.stringify(p));
  // Cloud sync (non-blocking) — if Supabase is configured
  if (USE_CLOUD) {
    Object.values(p).forEach(profile => {
      fetch(`${SB_URL}/rest/v1/profiles`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "apikey": SB_KEY,
          "Authorization": `Bearer ${SB_KEY}`,
          "Prefer": "resolution=merge-duplicates",
        },
        body: JSON.stringify({ id: profile.id, pin_hash: profile.pin, data: profile.data, name: profile.data?.name }),
      }).catch(() => {}); // silent fail — localStorage is source of truth
    });
  }
};

// Load profile from cloud (called on login if cloud is configured)
const loadFromCloud = async (name, pin) => {
  if (!USE_CLOUD) return null;
  try {
    const res = await fetch(
      `${SB_URL}/rest/v1/profiles?name=eq.${encodeURIComponent(name)}&pin_hash=eq.${encodeURIComponent(pin)}&select=*`,
      { headers: { "apikey": SB_KEY, "Authorization": `Bearer ${SB_KEY}` } }
    );
    const rows = await res.json();
    if (rows?.[0]) return { id: rows[0].id, name: rows[0].name, pin: rows[0].pin_hash, data: rows[0].data };
  } catch {}
  return null;
};

