// ─────────────────────────────────────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────────────────────────────────────
const fmt = (n, d = 0) =>
  new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: d }).format(n || 0);
const pct = (n, d = 1) => `${((n || 0) * 100).toFixed(d)}%`;
const num = v => parseFloat(v) || 0;
// Real (inflation-adjusted) value: nominal / (1+r)^n
const real = (nominal, inflRate, years) => nominal / Math.pow(1 + inflRate, years);
// Future value of lump sum
const fvLump = (pv, r, n) => pv * Math.pow(1 + r, n);
// Future value of annuity (end-of-period)
const fvAnnuity = (pmt, r, n) => r === 0 ? pmt * n : pmt * ((Math.pow(1 + r, n) - 1) / r);

// ─────────────────────────────────────────────────────────────────────────────
// 2026 TAX CONSTANTS
// ─────────────────────────────────────────────────────────────────────────────
const STD_DED = { single: 15000, married: 30000, hoh: 22500 };
const BRACKETS = {
  single:  [[11925,0.10],[48475,0.12],[103350,0.22],[197300,0.24],[250525,0.32],[626350,0.35],[Infinity,0.37]],
  married: [[23850,0.10],[96950,0.12],[206700,0.22],[394600,0.24],[501050,0.32],[751600,0.35],[Infinity,0.37]],
  hoh:     [[17000,0.10],[64850,0.12],[103350,0.22],[197300,0.24],[250500,0.32],[626350,0.35],[Infinity,0.37]],
};
const LTCG = {
  single:  [[48350,0.00],[533400,0.15],[Infinity,0.20]],
  married: [[96700,0.00],[600050,0.15],[Infinity,0.20]],
  hoh:     [[64750,0.00],[566700,0.15],[Infinity,0.20]],
};
const SS_BASE = 176100;
const LIMITS = { k401: 23500, ira: 7000, hsa_s: 4300, hsa_f: 8550 };

function calcFedTax(taxable, status) {
  const br = BRACKETS[status] || BRACKETS.single;
  let tax = 0, prev = 0;
  for (const [lim, rate] of br) {
    if (taxable <= prev) break;
    tax += (Math.min(taxable, lim) - prev) * rate;
    prev = lim;
    if (taxable <= lim) break;
  }
  return tax;
}
function calcFICA(wages, status) {
  const ss = Math.min(wages, SS_BASE) * 0.062;
  const med = wages * 0.0145;
  const addl = Math.max(0, wages - (status === "married" ? 250000 : 200000)) * 0.009;
  return { ss, med, addl, total: ss + med + addl };
}
function calcLTCGTax(gain, ordinaryIncome, status) {
  const thr = LTCG[status] || LTCG.single;
  let tax = 0, prev = 0, rem = gain;
  for (const [lim, rate] of thr) {
    const space = Math.max(0, lim - Math.max(ordinaryIncome, prev));
    const chunk = Math.min(rem, space);
    tax += chunk * rate;
    rem -= chunk;
    prev = lim;
    if (rem <= 0) break;
  }
  return tax;
}
function getMarginal(taxable, status) {
  const br = BRACKETS[status] || BRACKETS.single;
  let prev = 0;
  for (const [lim, rate] of br) { if (taxable <= lim) return rate; prev = lim; }
  return 0.37;
}
function niit(investIncome, agi, status) {
  return Math.max(0, Math.min(investIncome, agi - (status === "married" ? 250000 : 200000))) * 0.038;
}

