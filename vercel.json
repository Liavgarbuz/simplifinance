
import { useState, useEffect, useMemo, useCallback, useRef } from "react";

// ─────────────────────────────────────────────────────────────────────────────
// STYLES
// ─────────────────────────────────────────────────────────────────────────────
const CSS = `
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#f0ede8;--surface:#faf9f6;--surface2:#f0ede8;--surface3:#e8e4de;
  --border:#ddd9d0;--border2:#c8c3b8;
  --text:#1c1a16;--text2:#6b6659;--text3:#a09b8e;
  --green:#1a6b45;--green-bg:#eef7f2;--green-light:#c8ebd8;
  --red:#b83232;--red-bg:#fdf1f1;--red-light:#f5cccc;
  --amber:#9a6b1a;--amber-bg:#fdf6e8;--amber-light:#f5dfa0;
  --blue:#1a4f8a;--blue-bg:#eef3fb;--blue-light:#c0d5f0;
  --purple:#5a3d8a;--purple-bg:#f3eefb;--purple-light:#d5c8f5;
  --teal:#1a6b62;--teal-bg:#eef7f5;
  --shadow:0 1px 3px rgba(0,0,0,0.05),0 2px 8px rgba(0,0,0,0.04);
  --shadow-md:0 4px 16px rgba(0,0,0,0.08),0 1px 4px rgba(0,0,0,0.04);
  --shadow-lg:0 8px 32px rgba(0,0,0,0.10),0 2px 8px rgba(0,0,0,0.06);
  --r:12px;--r2:8px;--sidebar:248px;
  --font:'Plus Jakarta Sans',system-ui,sans-serif;
  --font-d:'Playfair Display',Georgia,serif;
}
body{background:var(--bg);color:var(--text);font-family:var(--font);font-size:14px;line-height:1.6;-webkit-font-smoothing:antialiased}
::selection{background:var(--green-light);color:var(--green)}
input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none;margin:0}
input[type=number]{-moz-appearance:textfield}
button{cursor:pointer;font-family:var(--font)}

/* SHELL */
.shell{display:flex;min-height:100vh}
.sidebar{width:var(--sidebar);background:var(--text);position:fixed;top:0;left:0;bottom:0;display:flex;flex-direction:column;z-index:200}
.sb-brand{padding:22px 20px 18px;border-bottom:1px solid rgba(255,255,255,0.07)}
.sb-name{font-family:var(--font-d);font-size:18px;color:#fff}
.sb-tag{font-size:10px;color:rgba(255,255,255,0.3);letter-spacing:0.12em;text-transform:uppercase;margin-top:2px}
.sb-nav{flex:1;padding:14px 10px;overflow-y:auto;display:flex;flex-direction:column;gap:1px}
.sb-sec{font-size:9px;color:rgba(255,255,255,0.22);text-transform:uppercase;letter-spacing:0.12em;padding:14px 12px 4px;font-weight:700}
.ni{display:flex;align-items:center;gap:9px;padding:8px 12px;border-radius:8px;color:rgba(255,255,255,0.5);font-size:12.5px;font-weight:500;cursor:pointer;border:none;background:none;width:100%;text-align:left;transition:all 0.13s}
.ni:hover{color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.05)}
.ni.on{color:#fff;background:rgba(255,255,255,0.11);font-weight:700}
.ni-ico{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.sb-foot{padding:14px 10px;border-top:1px solid rgba(255,255,255,0.07)}
.user-row{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:8px;cursor:pointer;transition:background 0.13s}
.user-row:hover{background:rgba(255,255,255,0.05)}
.uav{width:28px;height:28px;border-radius:50%;background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0}
.uname{font-size:11.5px;color:rgba(255,255,255,0.65);font-weight:500}
.uhint{font-size:9.5px;color:rgba(255,255,255,0.28)}

/* CONTENT */
.content{margin-left:var(--sidebar);flex:1;min-width:0}
.topbar{height:54px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;padding:0 26px;position:sticky;top:0;z-index:100;box-shadow:var(--shadow)}
.tb-title{font-family:var(--font-d);font-size:16px;color:var(--text);flex:1}
.page{padding:22px 26px 100px;max-width:1080px}

/* SEARCH */
.sw{position:relative;width:240px}
.si{width:100%;background:var(--surface2);border:1.5px solid var(--border);border-radius:999px;padding:6px 14px 6px 32px;font-size:12px;font-family:var(--font);color:var(--text);outline:none;transition:all 0.15s}
.si:focus{border-color:var(--green);background:#fff;box-shadow:0 0 0 3px var(--green-bg)}
.sico{position:absolute;left:11px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:12px;pointer-events:none}
.sr{position:absolute;top:calc(100%+5px);left:0;right:0;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow-md);z-index:300;max-height:280px;overflow-y:auto}
.sri{padding:9px 13px;cursor:pointer;border-bottom:1px solid var(--border);transition:background 0.1s}
.sri:last-child{border-bottom:none}
.sri:hover{background:var(--surface2)}
.sri-t{font-size:12px;font-weight:600;color:var(--text)}
.sri-s{font-size:10px;color:var(--text3);margin-top:1px}

/* INFLATION TOGGLE in topbar */
.inf-tog{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;border:1.5px solid var(--border);background:none;font-size:11px;font-weight:700;color:var(--text2);transition:all 0.15s;white-space:nowrap}
.inf-tog.on{border-color:var(--purple);background:var(--purple-bg);color:var(--purple)}
.inf-tog-dot{width:7px;height:7px;border-radius:50%;background:currentColor}

/* CARDS */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:20px;box-shadow:var(--shadow)}
.card-t{font-family:var(--font-d);font-size:15px;color:var(--text);margin-bottom:2px;font-weight:600}
.card-s{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;font-weight:700;margin-bottom:14px}
.card-h{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}

/* FOOTNOTE */
.fn{font-size:10px;color:var(--text3);margin-top:6px;line-height:1.5;font-style:italic;border-top:1px solid var(--border);padding-top:6px}
.fn-mark{color:var(--blue);font-weight:700;font-style:normal;cursor:help;text-decoration:underline dotted}

/* STAT */
.stat{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:16px 18px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.stat-bar{position:absolute;top:0;left:0;right:0;height:3px;border-radius:var(--r) var(--r) 0 0}
.stat-l{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.09em;font-weight:700;margin-bottom:6px}
.stat-v{font-family:var(--font-d);font-size:22px;color:var(--text);line-height:1.1;margin-bottom:3px}
.stat-v.infl{color:var(--purple)}
.stat-m{font-size:10.5px;color:var(--text2)}
.stat-m.up{color:var(--green)}.stat-m.dn{color:var(--red)}
.infl-badge{font-size:9px;background:var(--purple-bg);color:var(--purple);border-radius:4px;padding:1px 5px;font-weight:700;margin-left:4px;vertical-align:middle}

/* GRIDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:13px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:13px}
.stack{display:flex;flex-direction:column;gap:13px}

/* FORM */
.field{display:flex;flex-direction:column;gap:4px}
.lbl{font-size:10.5px;color:var(--text2);font-weight:700;letter-spacing:0.04em;text-transform:uppercase;display:flex;align-items:center;gap:4px}
.inp{background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--r2);color:var(--text);font-family:var(--font);font-size:13px;padding:7px 10px;outline:none;transition:all 0.13s;width:100%}
.inp:focus{border-color:var(--green);background:#fff;box-shadow:0 0 0 3px var(--green-bg)}
.inp::placeholder{color:var(--text3)}
.inp-p{position:relative}.inp-p .inp{padding-left:20px}
.inp-ps{position:absolute;left:8px;top:50%;transform:translateY(-50%);color:var(--text3);font-size:11px;pointer-events:none;z-index:1}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.frow3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px}

/* TOGGLE */
.tog{display:flex;background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--r2);overflow:hidden}
.tog-b{flex:1;padding:6px 11px;border:none;background:none;color:var(--text2);font-family:var(--font);font-size:11.5px;font-weight:600;transition:all 0.13s}
.tog-b.on{background:var(--text);color:#fff}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:var(--r2);border:none;font-family:var(--font);font-size:12.5px;font-weight:600;transition:all 0.13s}
.btn-dark{background:var(--text);color:#fff}.btn-dark:hover{background:#2d2b26}
.btn-green{background:var(--green);color:#fff}.btn-green:hover{opacity:.9}
.btn-ghost{background:none;border:1.5px solid var(--border);color:var(--text2)}.btn-ghost:hover{border-color:var(--border2);color:var(--text)}
.btn-sm{padding:4px 11px;font-size:11.5px}
.btn-del{background:none;border:none;color:var(--text3);font-size:12px;padding:3px 6px;border-radius:4px;transition:color 0.13s}.btn-del:hover{color:var(--red)}
.btn-add{display:flex;align-items:center;justify-content:center;gap:5px;background:none;border:1.5px dashed var(--border2);border-radius:var(--r2);padding:8px;color:var(--text3);font-size:11.5px;font-weight:600;width:100%;transition:all 0.13s}.btn-add:hover{color:var(--green);border-color:var(--green);background:var(--green-bg)}

/* TOOLTIP */
.tip{position:relative;display:inline-flex;align-items:center;cursor:help}
.tip-i{width:12px;height:12px;border-radius:50%;background:var(--surface3);color:var(--text3);font-size:7px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.tip-box{position:absolute;bottom:calc(100%+5px);left:50%;transform:translateX(-50%);background:#1c1a16;color:#fff;font-size:10.5px;line-height:1.55;padding:7px 11px;border-radius:8px;width:230px;z-index:9999;pointer-events:none;opacity:0;transition:opacity 0.13s;font-family:var(--font);font-weight:400;white-space:normal}
.tip:hover .tip-box{opacity:1}
.tip-box::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:4px solid transparent;border-top-color:#1c1a16}

/* BADGE */
.badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:999px;font-size:10px;font-weight:700;letter-spacing:0.03em}
.bg{background:var(--green-bg);color:var(--green)}.br{background:var(--red-bg);color:var(--red)}
.ba{background:var(--amber-bg);color:var(--amber)}.bb{background:var(--blue-bg);color:var(--blue)}
.bp{background:var(--purple-bg);color:var(--purple)}

/* INSIGHT */
.ins{border-radius:var(--r2);padding:12px 15px;display:flex;flex-direction:column;gap:4px}
.ins.g{background:var(--green-bg);border:1px solid var(--green-light)}
.ins.a{background:var(--amber-bg);border:1px solid var(--amber-light)}
.ins.b{background:var(--blue-bg);border:1px solid var(--blue-light)}
.ins.r{background:var(--red-bg);border:1px solid var(--red-light)}
.ins.p{background:var(--purple-bg);border:1px solid var(--purple-light)}
.ins-l{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em}
.ins.g .ins-l{color:var(--green)}.ins.a .ins-l{color:var(--amber)}.ins.b .ins-l{color:var(--blue)}.ins.r .ins-l{color:var(--red)}.ins.p .ins-l{color:var(--purple)}
.ins p{font-size:11.5px;color:var(--text2);line-height:1.6}

/* DISCLAIMER */
.disclaimer{background:var(--amber-bg);border:1.5px solid var(--amber-light);border-radius:var(--r2);padding:12px 15px}
.disclaimer-t{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:var(--amber);margin-bottom:4px}
.disclaimer p{font-size:11px;color:var(--text2);line-height:1.6}

/* COACH */
.coach{background:linear-gradient(135deg,#111d16 0%,#0d2b1f 100%);border-radius:var(--r);padding:20px 24px;color:#fff;position:relative;overflow:hidden}
.coach::before{content:'';position:absolute;top:-50px;right:-50px;width:180px;height:180px;border-radius:50%;background:rgba(26,107,69,0.12)}
.coach-hi{font-size:10px;color:rgba(255,255,255,0.38);text-transform:uppercase;letter-spacing:0.1em;font-weight:700;margin-bottom:4px}
.coach-msg{font-family:var(--font-d);font-size:15px;font-weight:600;line-height:1.5;margin-bottom:12px;color:rgba(255,255,255,0.93)}
.coach-tips{display:flex;flex-direction:column;gap:4px}
.coach-tip{font-size:11.5px;color:rgba(255,255,255,0.55);display:flex;gap:7px;line-height:1.5}
.coach-tip::before{content:'→';color:#3dd68c;flex-shrink:0}

/* BAR CHART */
.bars{display:flex;flex-direction:column;gap:8px}
.brow{display:grid;grid-template-columns:120px 1fr 75px;gap:9px;align-items:center}
.blbl{font-size:10.5px;color:var(--text2);text-align:right;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.btrack{background:var(--surface3);border-radius:99px;height:5px;overflow:hidden;position:relative}
.bfill{height:100%;border-radius:99px;transition:width 0.5s cubic-bezier(.4,0,.2,1)}
.bfill-ghost{position:absolute;top:0;height:100%;border-radius:99px;opacity:0.35}
.bval{font-size:10.5px;color:var(--text);font-variant-numeric:tabular-nums;font-weight:600;text-align:right}

/* TABLE */
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;font-weight:700;padding:0 9px 8px;text-align:left;border-bottom:1.5px solid var(--border);white-space:nowrap}
.tbl th.r{text-align:right}
.tbl td{padding:8px 9px;border-bottom:1px solid var(--border);font-size:11.5px;color:var(--text);vertical-align:middle}
.tbl td.r{text-align:right;font-variant-numeric:tabular-nums}
.tbl tr:last-child td{border-bottom:none}
.tbl tr:hover td{background:rgba(0,0,0,0.013)}
.ti{background:transparent;border:none;outline:none;color:var(--text);font-family:var(--font);font-size:11.5px;width:100%;min-width:0;text-align:inherit}
.ti:focus{background:var(--green-bg);border-radius:3px;padding:1px 3px;outline:1px solid var(--green)}

/* SUB-TABS */
.stabs{display:flex;gap:5px;margin-bottom:18px;flex-wrap:wrap}
.stab{padding:5px 13px;border-radius:999px;border:1.5px solid var(--border);background:none;color:var(--text2);font-size:11px;font-weight:700;font-family:var(--font);transition:all 0.13s;letter-spacing:0.03em}
.stab:hover{border-color:var(--border2);color:var(--text)}
.stab.on{background:var(--text);color:#fff;border-color:var(--text)}

/* DONUT */
.donut-wrap{display:flex;align-items:center;gap:18px;flex-wrap:wrap}
.legend{display:flex;flex-direction:column;gap:6px;flex:1;min-width:110px}
.leg-row{display:flex;align-items:center;gap:6px;font-size:10.5px}
.leg-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* DIVIDER */
.div{height:1px;background:var(--border);margin:14px 0}

/* TAX ROWS */
.tax-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)}
.tax-row:last-child{border-bottom:none}
.tax-row.sub .tax-lbl{padding-left:16px;font-size:11.5px;color:var(--text3)}
.tax-row.total{border-top:2px solid var(--border);border-bottom:none;padding-top:12px;margin-top:4px}
.tax-lbl{font-size:12.5px;color:var(--text2)}
.tax-v{font-size:12.5px;font-weight:700;font-family:var(--font-d);color:var(--text)}
.tax-v.r{color:var(--red)}.tax-v.g{color:var(--green)}.tax-v.a{color:var(--amber)}

/* ─── VISUAL TIMELINE ─── */
.vtl{position:relative;padding:0 0 8px}
.vtl-track{position:absolute;left:28px;top:24px;bottom:0;width:2px;background:linear-gradient(to bottom,var(--border),transparent)}
.vtl-item{display:flex;gap:16px;align-items:flex-start;margin-bottom:0;position:relative}
.vtl-left{display:flex;flex-direction:column;align-items:center;gap:0;flex-shrink:0;width:58px}
.vtl-yr{font-size:9px;font-weight:800;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;text-align:center;margin-bottom:4px}
.vtl-icon-wrap{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;border:3px solid var(--surface);box-shadow:var(--shadow-md);position:relative;z-index:2;flex-shrink:0}
.vtl-connector{width:2px;flex:1;min-height:24px;background:var(--border);margin:0 auto}
.vtl-body{flex:1;padding-bottom:24px}
.vtl-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;box-shadow:var(--shadow)}
.vtl-card.highlight{border-color:var(--green);box-shadow:0 0 0 3px var(--green-bg),var(--shadow)}
.vtl-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:7px}
.vtl-row{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:6px}
.vtl-chip{font-size:10px;padding:2px 8px;border-radius:999px;font-weight:700;display:inline-flex;align-items:center;gap:3px}
.vtl-impact{font-size:11px;color:var(--text2);margin-top:4px;padding-top:6px;border-top:1px solid var(--border)}
.vtl-nw{font-size:12px;font-weight:700;margin-top:5px}
.vtl-nw-delta{font-size:10px;color:var(--text3)}

/* NET WORTH CHART SVG */
.nwchart{width:100%;overflow:visible}

/* CHATBOT */
.chat-fab{position:fixed;bottom:22px;right:22px;width:50px;height:50px;border-radius:50%;background:var(--green);border:none;color:#fff;font-size:19px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-lg);z-index:500;transition:all 0.18s}
.chat-fab:hover{transform:scale(1.06)}
.chat-panel{position:fixed;bottom:84px;right:22px;width:340px;background:var(--surface);border:1px solid var(--border);border-radius:14px;box-shadow:var(--shadow-lg);z-index:500;display:flex;flex-direction:column;max-height:500px;overflow:hidden}
.chat-head{padding:12px 14px;background:var(--text);border-radius:14px 14px 0 0;display:flex;align-items:center;justify-content:space-between}
.chat-ht{font-size:12.5px;font-weight:700;color:#fff;display:flex;align-items:center;gap:7px}
.chat-hc{background:none;border:none;color:rgba(255,255,255,0.45);font-size:15px}.chat-hc:hover{color:#fff}
.chat-msgs{flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:9px;min-height:180px}
.msg{max-width:88%;border-radius:11px;padding:8px 11px;font-size:11.5px;line-height:1.6}
.msg.user{background:var(--green);color:#fff;align-self:flex-end;border-bottom-right-radius:2px}
.msg.ai{background:var(--surface2);color:var(--text);align-self:flex-start;border-bottom-left-radius:2px;border:1px solid var(--border)}
.msg.loading{color:var(--text3);font-style:italic}
.chat-inp-row{display:flex;gap:7px;padding:10px;border-top:1px solid var(--border)}
.chat-inp{flex:1;background:var(--surface2);border:1.5px solid var(--border);border-radius:999px;padding:7px 12px;font-size:11.5px;font-family:var(--font);color:var(--text);outline:none;transition:border-color 0.13s}
.chat-inp:focus{border-color:var(--green);background:#fff}
.chat-send{background:var(--green);color:#fff;border:none;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;transition:opacity 0.13s}
.chat-send:hover{opacity:.85}

/* LOGIN */
.login-bg{min-height:100vh;display:flex;align-items:center;justify-content:center;background:var(--bg);padding:20px}
.login-card{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:40px 36px;width:100%;max-width:390px;box-shadow:var(--shadow-lg)}
.login-brand{font-family:var(--font-d);font-size:24px;text-align:center;margin-bottom:3px}
.login-sub{font-size:11.5px;color:var(--text3);text-align:center;margin-bottom:28px}
.login-err{background:var(--red-bg);border:1px solid var(--red-light);color:var(--red);border-radius:7px;padding:8px 13px;font-size:12px;text-align:center}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
.fu{animation:fadeUp 0.22s ease both}

/* RESPONSIVE */
@media(max-width:860px){
  .sidebar{transform:translateX(-100%)}.content{margin-left:0}
