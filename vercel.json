          <div className="fn">State tax estimated as: AGI × {d.stateRate}%. Effective rate = Total Tax ÷ Gross Income. Marginal rate = your top federal bracket rate on last dollar of ordinary income.</div>
        </div>
      </div>
      <div className="card">
        <div className="card-t">Cash & Liabilities</div><div className="card-s">Balances & debt</div>
        <div className="stack" style={{ gap: 9 }}>
          {[["checkingBal","🏦 Checking Account"],["savingsBal","💰 Savings / HYSA"],["emergencyFund","🛡 Emergency Fund"]].map(([k, l]) =>
            <div className="field" key={k}><label className="lbl">{l}</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={d[k]} onChange={e => upd({ [k]: e.target.value })}/></div></div>
