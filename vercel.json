function Tip({ k, children }) {
  return <span className="tip">{children}<span className="tip-i">?</span><span className="tip-box">{TIPS[k] || k}</span></span>;
}

function Spark({ data, color = "var(--green)", data2 = null, color2 = "var(--purple)", ht = 70 }) {
  if (!data || data.length < 2) return null;
  const all = [...data, ...(data2 || [])];
  const maxV = Math.max(...all), minV = Math.min(...all, 0);
  const range = maxV - minV || 1;
  const W = 400, H = ht, p = 4;
  const toX = i => p + (i / (data.length - 1)) * (W - p * 2);
  const toY = v => H - p - ((v - minV) / range) * (H - p * 2);
  const mkPath = arr => arr.map((v, i) => `${i === 0 ? "M" : "L"}${toX(i).toFixed(1)},${toY(v).toFixed(1)}`).join(" ");
  const mkArea = arr => { const d = mkPath(arr); return `${d} L${toX(arr.length-1)},${H} L${toX(0)},${H} Z`; };
  const id1 = `sg1${color.replace(/[^a-z]/gi,"")}`;
  const id2 = `sg2${color2.replace(/[^a-z]/gi,"")}`;
  return <svg viewBox={`0 0 ${W} ${H}`} style={{ width: "100%", height: ht }} preserveAspectRatio="none">
    <defs>
      <linearGradient id={id1} x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stopColor={color} stopOpacity="0.15"/><stop offset="100%" stopColor={color} stopOpacity="0"/></linearGradient>
      {data2 && <linearGradient id={id2} x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stopColor={color2} stopOpacity="0.10"/><stop offset="100%" stopColor={color2} stopOpacity="0"/></linearGradient>}
    </defs>
    <path d={mkArea(data)} fill={`url(#${id1})`}/>
    <path d={mkPath(data)} fill="none" stroke={color} strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"/>
    {data2 && <>
      <path d={mkArea(data2)} fill={`url(#${id2})`}/>
      <path d={mkPath(data2)} fill="none" stroke={color2} strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" strokeDasharray="6 3"/>
    </>}
  </svg>;
}

function Donut({ slices, size = 140, stroke = 26, ctr, sub }) {
  const r = (size - stroke) / 2, circ = 2 * Math.PI * r;
  const valid = slices.filter(s => s.value > 0);
  const total = valid.reduce((s, x) => s + x.value, 0);
  let cum = 0;
  return <div className="donut-wrap">
    <svg width={size} height={size} style={{ flexShrink: 0 }}>
      <circle cx={size/2} cy={size/2} r={r} fill="none" stroke="var(--surface3)" strokeWidth={stroke}/>
      {valid.map((s, i) => {
        const f = s.value / total, dash = f * circ, off = -cum * circ + circ * 0.25;
        cum += f;
        return <circle key={i} cx={size/2} cy={size/2} r={r} fill="none" stroke={s.color} strokeWidth={stroke}
          strokeDasharray={`${dash} ${circ - dash}`} strokeDashoffset={off}
          style={{ transform: "rotate(-90deg)", transformOrigin: "center" }}/>;
      })}
      {ctr && <>
        <text x={size/2} y={size/2-5} textAnchor="middle" fill="var(--text)" fontFamily="var(--font-d)" fontSize="12" fontWeight="600">{ctr}</text>
        <text x={size/2} y={size/2+8} textAnchor="middle" fill="var(--text3)" fontFamily="var(--font)" fontSize="8">{sub}</text>
      </>}
    </svg>
    <div className="legend">
      {valid.map((s, i) => <div key={i} className="leg-row">
        <span className="leg-dot" style={{ background: s.color }}/>
        <span style={{ color: "var(--text2)", flex: 1 }}>{s.label}</span>
        <span style={{ fontWeight: 600, fontVariantNumeric: "tabular-nums" }}>{fmt(s.value)}</span>
        <span style={{ color: "var(--text3)", marginLeft: 4, fontSize: 10 }}>{total > 0 ? pct(s.value / total) : "—"}</span>
      </div>)}
    </div>
  </div>;
}

function Bars({ rows, showGhost = false }) {
  const max = Math.max(...rows.map(r => Math.max(r.value, r.ghost || 0)), 1);
  return <div className="bars">
    {rows.map((r, i) => <div key={i} className="brow">
      <span className="blbl">{r.label}</span>
      <div className="btrack">
        {showGhost && r.ghost > 0 && <div className="bfill-ghost" style={{ width: `${(r.ghost / max) * 100}%`, background: r.color || "var(--green)" }}/>}
        <div className="bfill" style={{ width: `${(r.value / max) * 100}%`, background: r.color || "var(--green)" }}/>
      </div>
      <span className="bval">{r.pct ? pct(r.value) : fmt(r.value)}</span>
    </div>)}
  </div>;
}

function Disclaimer() {
  return <div className="disclaimer">
    <div className="disclaimer-t">⚠ Educational Tool — Not Professional Financial Advice</div>
    <p>SimpliFinance is a <strong>visualization and insights tool</strong>. All projections, estimates, and suggestions are based on publicly available formulas and general financial planning guidelines. They do <strong>not</strong> reflect the views or recommendations of a Certified Financial Planner (CFP), CFA, CPA, or any licensed financial advisor. Tax calculations are estimates — consult a tax professional for your actual return. Investment projections assume constant rates and do not account for market volatility or sequence-of-returns risk. Past performance does not predict future results.</p>
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH SCREEN
// ─────────────────────────────────────────────────────────────────────────────
function AuthScreen({ onLogin }) {
  const [mode, setMode] = useState("login");
  const [name, setName] = useState(""), [pin, setPin] = useState(""), [confirm, setConfirm] = useState(""), [err, setErr] = useState(""), [loading, setLoading] = useState(false);
  const go = async () => {
    setErr("");
    setLoading(true);
    const ps = loadP();
    if (mode === "register") {
      if (!name.trim()) { setLoading(false); return setErr("Enter your name."); }
      if (pin.length < 4) { setLoading(false); return setErr("PIN must be 4+ characters."); }
      if (pin !== confirm) { setLoading(false); return setErr("PINs don't match."); }
      const id = name.toLowerCase().replace(/\s+/g, "_") + "_" + Date.now();
      ps[id] = { id, name: name.trim(), pin, data: mkDefault(name.trim()) };
      saveP(ps); setLoading(false); onLogin(ps[id]);
    } else {
      // Try cloud first, then local
      let m = null;
      if (USE_CLOUD) {
        m = await loadFromCloud(name.trim(), pin);
        if (m) {
          // Merge cloud data into localStorage
          ps[m.id] = m; saveP(ps);
        }
      }
      if (!m) m = Object.values(ps).find(p => p.name.toLowerCase() === name.toLowerCase() && p.pin === pin);
      if (!m) { setLoading(false); return setErr("Name or PIN not found."); }
      setLoading(false); onLogin(m);
    }
  };
  return <div className="login-bg"><div className="login-card fu">
    <div className="login-brand">SimpliFinance</div>
    <div className="login-sub">{mode === "login" ? "Sign in to your profile." : "Create your personal finance profile."}</div>
    <div className="stack" style={{ gap: 11 }}>
      <div className="field"><label className="lbl">Name</label><input className="inp" placeholder="e.g. Alex" value={name} onChange={e => setName(e.target.value)} onKeyDown={e => e.key === "Enter" && go()}/></div>
      <div className="field"><label className="lbl">PIN / Password</label><input className="inp" type="password" placeholder="••••" value={pin} onChange={e => setPin(e.target.value)} onKeyDown={e => e.key === "Enter" && go()}/></div>
      {mode === "register" && <div className="field"><label className="lbl">Confirm PIN</label><input className="inp" type="password" placeholder="••••" value={confirm} onChange={e => setConfirm(e.target.value)} onKeyDown={e => e.key === "Enter" && go()}/></div>}
      {err && <div className="login-err">{err}</div>}
      <button className="btn btn-dark" style={{ width: "100%", justifyContent: "center", padding: "10px" }} onClick={go}>{loading ? "⏳ Signing in…" : mode === "login" ? "Sign In →" : "Create Profile"}</button>
    </div>
    <div style={{ textAlign: "center", fontSize: 11.5, color: "var(--text3)", marginTop: 11 }}>
      {mode === "login" ? <><span style={{ color: "var(--green)", cursor: "pointer", fontWeight: 600 }} onClick={() => { setMode("register"); setErr(""); }}>New? Create a profile</span></> : <><span style={{ color: "var(--green)", cursor: "pointer", fontWeight: 600 }} onClick={() => { setMode("login"); setErr(""); }}>Sign in instead</span></>}
    </div>
    <div style={{ marginTop: 14, background: "var(--green-bg)", borderRadius: 7, padding: "9px 13px", fontSize: 11, color: "var(--green)" }}>{USE_CLOUD ? "☁️ Cloud sync enabled — your data follows you across all devices." : "🔒 Data stored locally on this device. Set up Supabase for cross-device sync."}</div>
  </div></div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// OVERVIEW TAB
// ─────────────────────────────────────────────────────────────────────────────
function Overview({ d, budget, prices, inflOn, inflRate }) {
  const { gross, netAnnual, annualSavings, savingsRate, totalTax, marginal } = budget;
  const allH = d.accounts.flatMap(a => a.holdings);
  const getP = h => prices[h.ticker?.toUpperCase()]?.price || num(h.price);
  const totPort = allH.reduce((s, h) => s + num(h.shares) * getP(h), 0);
  const totDivs = allH.reduce((s, h) => s + num(h.shares) * num(h.div), 0);
  const cash = num(d.checkingBal) + num(d.savingsBal) + num(d.emergencyFund);
  const totLiab = d.liabilities.reduce((s, l) => s + num(l.balance), 0);
  const nomNW = totPort + cash - totLiab;
  const projRows = buildProjection({ budget, d, prices, inflRate, years: 10 });
  const nomProj = projRows.map(r => r.nominalNW);
  const realProj = projRows.map(r => r.realNW);
  const retRows = buildProjection({ budget, d, prices, inflRate, years: Math.max(1, d.retireAge - d.age) });
  const retNW = retRows[retRows.length - 1]?.nominalNW || 0;
  const safeWith = retNW * 0.04;

  const tips = [];
  if (savingsRate < 0.15) tips.push(`Savings rate is ${pct(savingsRate)} — below the 15–20% recommended threshold. Boosting it by 5% adds ${fmt(gross * 0.05)}/yr.`);
  else tips.push(`Savings rate of ${pct(savingsRate)} is solid. Keep compounding.`);
  if (totDivs > 0) tips.push(`Portfolio generates ${fmt(totDivs / 12)}/mo in dividends (${fmt(totDivs)}/yr passive income).`);
  if (marginal >= 0.22) tips.push(`At ${pct(marginal)} marginal rate, maxing your 401(k) to $${LIMITS.k401.toLocaleString()}/yr saves ~${fmt((LIMITS.k401 - budget.pre401k) * marginal)} in federal taxes.`);

  return <div className="stack fu">
    <Disclaimer/>
    <div className="coach">
      <div className="coach-hi">👋 Hey {d.name},</div>
      <div className="coach-msg">Based on your current savings rate, you could reach {fmt(retNW)} by age {d.retireAge} — potentially generating {fmt(safeWith / 12)}/month using the 4% withdrawal rule{inflOn ? ` (${fmt(real(retNW, inflRate / 100, d.retireAge - d.age))} in today's dollars)` : ""}.{" "}
        <span style={{ fontSize: 11, color: "rgba(255,255,255,0.45)", fontFamily: "var(--font)", fontWeight: 400 }}>These are projections only — see disclaimer above.</span>
      </div>
      <div className="coach-tips">{tips.map((t, i) => <div key={i} className="coach-tip">{t}</div>)}</div>
    </div>
    <div className="g4">
      {[
        ["Net Worth", nomNW, inflOn ? real(nomNW, inflRate/100, 0) : null, "Total assets minus liabilities", "var(--green)"],
        ["Annual Savings", annualSavings, inflOn ? real(annualSavings, inflRate/100, 1) : null, `${pct(savingsRate)} of gross income`, "var(--blue)"],
        ["Portfolio Value", totPort, null, `${allH.length} holdings · ${d.accounts.length} accounts`, "var(--amber)"],
        ["Est. Tax Bill", totalTax, null, `${pct(budget.effective)} effective · ${pct(marginal)} marginal`, "var(--red)"],
      ].map(([lbl, nom, rl, meta, c]) => <div key={lbl} className="stat">
        <div className="stat-bar" style={{ background: c }}/>
        <div className="stat-l">{lbl}</div>
        <div className="stat-v">{fmt(nom)}</div>
        {inflOn && rl !== null && <div className="stat-v infl" style={{ fontSize: 14, marginBottom: 2 }}>{fmt(rl)} <span className="infl-badge">real</span></div>}
        <div className="stat-m">{meta}</div>
      </div>)}
    </div>
    <div className="g2">
      <div className="card">
        <div className="card-t">Income Allocation</div><div className="card-s">Annual — where it goes</div>
        <Donut ctr={fmt(gross)} sub="gross" slices={[
          { label: "Federal + State Tax", value: Math.max(0, totalTax), color: "var(--red)" },
          { label: "Expenses", value: budget.expMonthly * 12, color: "var(--blue)" },
          { label: "Retirement Contribs", value: budget.retMonthly * 12, color: "var(--teal)" },
          { label: "Free Savings", value: Math.max(0, annualSavings), color: "var(--green)" },
        ].filter(s => s.value > 0)}/>
        <div className="fn">Formula: Savings = Gross − Taxes − Expenses − Retirement Contributions. "Expenses" = total monthly expenses × 12. "Retirement" = sum of all account monthly contributions × 12.</div>
      </div>
      <div className="card">
        <div className="card-t">10-Year Net Worth Projection{inflOn ? " (with Inflation)" : ""}</div>
        <div className="card-s">Nominal{inflOn ? " vs. Inflation-Adjusted (real)" : ""} · Today's Dollars</div>
        <Spark data={nomProj} data2={inflOn ? realProj : null} ht={100}/>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 7 }}>
          <span style={{ fontSize: 10.5, color: "var(--text3)" }}>Today: {fmt(nomNW)}</span>
          <span style={{ fontSize: 10.5, color: "var(--green)", fontWeight: 700 }}>Yr 10: {fmt(nomProj[10])}</span>
        </div>
        {inflOn && <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 3 }}>
          <span style={{ fontSize: 10, color: "var(--purple)", fontWeight: 600 }}>Real Yr 10: {fmt(realProj[10])} ≈ {pct((realProj[10]/nomProj[10])-1)} purchasing power</span>
        </div>}
        <div className="fn"><span className="fn-mark">Nominal</span>: future dollars. <span className="fn-mark">Real</span>: inflation-adjusted using {inflRate}%/yr. Formula: Real = Nominal ÷ (1+{inflRate/100})^n. Portfolio growth uses weighted average expected return of holdings.</div>
      </div>
    </div>
    <div className="g2">
      <div className="card">
        <div className="card-t">Monthly Cash Flow</div><div className="card-s">Take-home vs outflows</div>
        <Bars rows={[
          { label: "Take-Home", value: netAnnual / 12, color: "var(--text2)" },
          { label: "Housing", value: d.expenses.filter(e => e.cat === "housing").reduce((s, e) => s + num(e.amount), 0), color: "var(--blue)" },
          { label: "All Other Exp.", value: d.expenses.filter(e => e.cat !== "housing").reduce((s, e) => s + num(e.amount), 0), color: "var(--amber)" },
          { label: "Retirement", value: budget.retMonthly, color: "var(--teal)" },
          { label: "Debt Payments", value: budget.debtPayments, color: "var(--red)" },
          { label: "Monthly Savings", value: Math.max(0, annualSavings / 12), color: "var(--green)" },
        ].filter(r => r.value > 0)}/>
        <div className="fn">Take-Home = Gross − Total Taxes. Monthly Savings = Take-Home − All Expenses − Retirement Contributions − Debt Payments.</div>
      </div>
      <div className="card">
        <div className="card-t">Retirement Snapshot</div><div className="card-s">Age {d.retireAge} projection</div>
        {[
          ["Projected Balance", fmt(retNW), "var(--purple)", null],
          [inflOn ? "Real Balance (today's $)" : null, inflOn ? fmt(real(retNW, inflRate/100, d.retireAge-d.age)) : null, "var(--purple)", null],
          ["4% Withdrawal / yr", fmt(safeWith), "var(--green)", "safe4"],
          ["4% Withdrawal / mo", fmt(safeWith / 12), "var(--green)", null],
          ["Years until retirement", `${Math.max(0, d.retireAge - d.age)} yrs`, "var(--blue)", null],
        ].filter(([l]) => l).map(([l, v, c, t]) => <div key={l} style={{ display: "flex", justifyContent: "space-between", paddingBottom: 9, borderBottom: "1px solid var(--border)" }}>
          <span style={{ fontSize: 12, color: "var(--text2)" }}>{t ? <Tip k={t}>{l + " "}</Tip> : l}</span>
          <span style={{ fontFamily: "var(--font-d)", fontSize: 14, color: c, fontWeight: 600 }}>{v}</span>
        </div>)}
        <div className="fn">Projection uses compound growth formula: FV = PV × (1+r)^n + PMT × ((1+r)^n − 1) / r. r = weighted portfolio return ({pct(d.accounts.flatMap(a=>a.holdings).reduce((s,h,_,arr)=>s+(num(h.shares)*num(h.price)/Math.max(arr.reduce((t,x)=>t+num(x.shares)*num(x.price),0),1))*num(h.expRet),0)/100)}/yr assumed).</div>
      </div>
    </div>
  </div>;
}

