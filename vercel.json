            <span style={{ fontSize: 12, fontWeight: 700, color: "var(--text2)" }}>DEBTS</span>
            <button className="btn btn-ghost btn-sm" onClick={() => upd({ liabilities: [...d.liabilities, { id: nid(), label: "New Loan", balance: 0, rate: 0, payment: 0 }] })}>+ Add</button>
