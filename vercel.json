function BudgetTab({ d, upd, budget }) {
  const idR = useRef(100);
  const nid = () => ++idR.current;
  const { gross, netAnnual, annualSavings, fedTax, fica, stateTax, totalTax, marginal, effective } = budget;

  // Group expenses by MECE category
  const byCat = EXPENSE_CATS.map(cat => ({
    ...cat,
    items: d.expenses.filter(e => e.cat === cat.id),
    total: d.expenses.filter(e => e.cat === cat.id).reduce((s, e) => s + num(e.amount), 0),
  })).filter(c => c.items.length > 0 || true); // always show all for MECE completeness

  const totalExp = d.expenses.reduce((s, e) => s + num(e.amount), 0);

  return <div className="stack fu">
    {/* INCOME */}
    <div className="card">
      <div className="card-h">
        <div><div className="card-t">Income Sources</div><div className="card-s">Annual figures before tax</div></div>
        <button className="btn btn-ghost btn-sm" onClick={() => upd({ incomes: [...d.incomes, { id: nid(), label: "New Income", amount: 0, type: "w2" }] })}>+ Add</button>
      </div>
      <div className="stack" style={{ gap: 8 }}>
        {d.incomes.map(inc => <div key={inc.id} style={{ display: "grid", gridTemplateColumns: "1fr 110px 105px 28px", gap: 8, alignItems: "end" }}>
          <div className="field"><label className="lbl">Source</label><input className="inp" value={inc.label} onChange={e => upd({ incomes: d.incomes.map(i => i.id === inc.id ? { ...i, label: e.target.value } : i) })}/></div>
          <div className="field"><label className="lbl">Amount/yr</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={inc.amount} onChange={e => upd({ incomes: d.incomes.map(i => i.id === inc.id ? { ...i, amount: e.target.value } : i) })}/></div></div>
          <div className="field"><label className="lbl">Type</label>
            <select className="inp" value={inc.type} onChange={e => upd({ incomes: d.incomes.map(i => i.id === inc.id ? { ...i, type: e.target.value } : i) })}>
              <option value="w2">W-2 / Salary</option><option value="self">Self-Employed</option><option value="bonus">Bonus</option>
              <option value="rental">Rental</option><option value="dividends">Dividends</option><option value="other">Other</option>
            </select>
          </div>
          <button className="btn-del" onClick={() => upd({ incomes: d.incomes.filter(i => i.id !== inc.id) })}>✕</button>
        </div>)}
        <div style={{ maxWidth: 240 }}>
          <div className="field"><label className="lbl">Annual Bonus (included in W-2 totals)</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={d.bonus} onChange={e => upd({ bonus: e.target.value })}/></div></div>
        </div>
      </div>
      <div className="fn">W-2 wages are subject to FICA (Social Security 6.2% up to $176,100 + Medicare 1.45%). Self-employment income gets a 50% SE tax deduction above-the-line. Bonus is included in W-2 wage base for all calculations.</div>
    </div>

    {/* RETIREMENT */}
    <div className="card">
      <div className="card-t">Retirement Contributions</div><div className="card-s">Monthly — 2026 IRS limits</div>
      <div className="frow3" style={{ marginBottom: 10 }}>
        {[
          ["trad401k", "Traditional 401(k)", LIMITS.k401, "trad"],
          ["roth401k", "Roth 401(k)", LIMITS.k401, "roth"],
          ["rothIRA", "Roth IRA", LIMITS.ira, "roth"],
          ["tradIRA", "Traditional IRA", LIMITS.ira, "trad"],
          ["hsa", "HSA (single)", LIMITS.hsa_s, "niit"],
        ].map(([k, lbl, lim, tip]) => {
          const ann = num(d.retirement[k]) * 12;
