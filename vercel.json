            <div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={d.retirement[k]} onChange={e => upd({ retirement: { ...d.retirement, [k]: e.target.value } })} style={{ borderColor: over ? "var(--red)" : "" }}/></div>
