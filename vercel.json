          {d.liabilities.map(l => <div key={l.id} style={{ display: "grid", gridTemplateColumns: "1fr 65px 55px 60px 24px", gap: 6, alignItems: "end", marginBottom: 6 }}>
            <div className="field"><label className="lbl">Name</label><input className="inp" value={l.label} onChange={e => upd({ liabilities: d.liabilities.map(x => x.id === l.id ? { ...x, label: e.target.value } : x) })}/></div>
            <div className="field"><label className="lbl">Balance</label><input className="inp" type="number" value={l.balance} onChange={e => upd({ liabilities: d.liabilities.map(x => x.id === l.id ? { ...x, balance: e.target.value } : x) })}/></div>
            <div className="field"><label className="lbl">Rate %</label><input className="inp" type="number" value={l.rate} onChange={e => upd({ liabilities: d.liabilities.map(x => x.id === l.id ? { ...x, rate: e.target.value } : x) })}/></div>
            <div className="field"><label className="lbl">Pmt/mo</label><input className="inp" type="number" value={l.payment} onChange={e => upd({ liabilities: d.liabilities.map(x => x.id === l.id ? { ...x, payment: e.target.value } : x) })}/></div>
            <button className="btn-del" onClick={() => upd({ liabilities: d.liabilities.filter(x => x.id !== l.id) })}>✕</button>
          </div>)}
        </div>
      </div>
    </div>

    {/* MECE EXPENSES */}
    <div className="card">
      <div className="card-h">
        <div>
          <div className="card-t">Monthly Expenses <Tip k="mece"><span/></Tip></div>
          <div className="card-s">MECE categories — every dollar belongs to exactly one group</div>
        </div>
        <button className="btn btn-ghost btn-sm" onClick={() => upd({ expenses: [...d.expenses, { id: nid(), label: "New Expense", cat: "other", amount: 0 }] })}>+ Add Expense</button>
      </div>
      {EXPENSE_CATS.map(cat => {
        const items = d.expenses.filter(e => e.cat === cat.id);
        const catTotal = items.reduce((s, e) => s + num(e.amount), 0);
        return <div key={cat.id} style={{ marginBottom: 14 }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 6, paddingBottom: 4, borderBottom: "1px solid var(--border)" }}>
            <div style={{ display: "flex", alignItems: "center", gap: 7 }}>
              <span style={{ fontSize: 12, fontWeight: 700, color: "var(--text)" }}>{cat.label}</span>
              <span style={{ fontSize: 10, color: "var(--text3)" }}>{cat.hint}</span>
            </div>
            <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
              <span style={{ fontSize: 12, fontWeight: 700, color: "var(--text2)" }}>{catTotal > 0 ? fmt(catTotal) + "/mo" : ""}</span>
              <button className="btn-add" style={{ width: "auto", padding: "2px 10px", fontSize: 10 }} onClick={() => upd({ expenses: [...d.expenses, { id: nid(), label: cat.label, cat: cat.id, amount: 0 }] })}>+ Add</button>
            </div>
          </div>
          {items.map(e => <div key={e.id} style={{ display: "grid", gridTemplateColumns: "1fr 100px 24px", gap: 7, alignItems: "end", marginBottom: 6, paddingLeft: 10 }}>
            <div className="field"><label className="lbl">Label</label><input className="inp" value={e.label} onChange={ev => upd({ expenses: d.expenses.map(x => x.id === e.id ? { ...x, label: ev.target.value } : x) })}/></div>
            <div className="field"><label className="lbl">$/month</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={e.amount} onChange={ev => upd({ expenses: d.expenses.map(x => x.id === e.id ? { ...x, amount: ev.target.value } : x) })}/></div></div>
            <button className="btn-del" onClick={() => upd({ expenses: d.expenses.filter(x => x.id !== e.id) })}>✕</button>
          </div>)}
          {items.length === 0 && <div style={{ paddingLeft: 10, fontSize: 11, color: "var(--text3)", fontStyle: "italic" }}>None added — add one above if applicable.</div>}
        </div>;
      })}
      <div className="div"/>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
        <span style={{ fontSize: 13, color: "var(--text2)", fontWeight: 600 }}>Total Monthly Expenses (all categories)</span>
        <span style={{ fontFamily: "var(--font-d)", fontSize: 18, color: "var(--blue)", fontWeight: 700 }}>{fmt(totalExp)}/mo · {fmt(totalExp * 12)}/yr</span>
      </div>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginTop: 8 }}>
        <span style={{ fontSize: 13, color: "var(--text2)", fontWeight: 600 }}>Projected Annual Savings</span>
        <span style={{ fontFamily: "var(--font-d)", fontSize: 20, color: annualSavings >= 0 ? "var(--green)" : "var(--red)", fontWeight: 700 }}>{fmt(annualSavings)}</span>
      </div>
      <div className="fn">Annual Savings = Net Take-Home − (Monthly Expenses × 12) − (Retirement Contributions × 12) − (Debt Payments × 12). Net Take-Home = Gross Income − Total Taxes.</div>
    </div>
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// TAX TAB
// ─────────────────────────────────────────────────────────────────────────────
function TaxTab({ d, budget, prices }) {
  const { gross, w2, se, passive, pre401k, tradIRA, hsaDed, seDed, slIntDed, agi, stdDed, ded, credits, taxable, fedTax, fica, stateTax, totalTax, marginal, effective } = budget;
  const allH = d.accounts.flatMap(a => a.holdings);
  const taxH = allH.filter(h => !TAX_ADV.includes(d.accounts.find(a => a.holdings.some(x => x.id === h.id))?.type));
  const getP = h => prices[h.ticker?.toUpperCase()]?.price || num(h.price);
  const divIncome = d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings).reduce((s, h) => s + num(h.shares) * num(h.div), 0);
  const ltGain = d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings).filter(h => h.gainType === "long").reduce((s, h) => s + Math.max(0, num(h.shares) * getP(h) - num(h.shares) * num(h.cost)), 0);
  const stGain = d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings).filter(h => h.gainType === "short").reduce((s, h) => s + Math.max(0, num(h.shares) * getP(h) - num(h.shares) * num(h.cost)), 0);
  const ltTax = calcLTCGTax(ltGain, taxable, d.filingStatus);
  const stTax = stGain * marginal;
  const niitTax = niit(divIncome + ltGain + stGain, agi, d.filingStatus);
  const totalWithInvest = totalTax + ltTax + niitTax;
  const TR = ({ label, value, color = "", sub = false, total = false }) =>
    <div className={`tax-row${sub ? " sub" : ""}${total ? " total" : ""}`}>
      <span className="tax-lbl">{label}</span>
      <span className={`tax-v ${color}`}>{value}</span>
    </div>;

  return <div className="stack fu">
    <div className="ins b"><div className="ins-l">📅 2026 Tax Year Data</div>
      <p>Standard deductions: {fmt(STD_DED.single)} (single) / {fmt(STD_DED.married)} (MFJ). FICA SS wage base: ${SS_BASE.toLocaleString()}. 401(k) limit: $23,500. IRA limit: $7,000. HSA single: $4,300. NIIT threshold: $200k (single) / $250k (MFJ). All calculations use the formulas shown in footnotes below.</p>
    </div>
    <div className="g2">
      <div className="card">
        <div className="card-t">Income → Taxable Income</div><div className="card-s">Step-by-step AGI calculation</div>
        <TR label="W-2 Wages & Salary" value={fmt(w2)}/>
        {se > 0 && <TR label="Self-Employment Income" value={fmt(se)}/>}
        {num(d.bonus) > 0 && <TR label="  Bonus / Commission" value={fmt(num(d.bonus))} sub/>}
        {passive > 0 && <TR label="Other Income (rental, etc.)" value={fmt(passive)}/>}
        {divIncome > 0 && <TR label="Dividends (taxable accounts)" value={fmt(divIncome)}/>}
        <TR label="= Gross Income" value={fmt(gross)} color="a"/>
        <div className="div"/>
        <TR label="− Pre-Tax 401(k) Contributions" value={`(${fmt(pre401k)})`} color="g"/>
        {tradIRA > 0 && <TR label="− Traditional IRA Deduction" value={`(${fmt(tradIRA)})`} color="g"/>}
        {hsaDed > 0 && <TR label="− HSA Deduction" value={`(${fmt(hsaDed)})`} color="g"/>}
        {seDed > 0 && <TR label="− SE Tax Deduction (50% of SE tax)" value={`(${fmt(seDed)})`} color="g"/>}
        {slIntDed > 0 && <TR label="− Student Loan Interest Deduction" value={`(${fmt(slIntDed)})`} color="g"/>}
        <TR label="= Adjusted Gross Income (AGI)" value={fmt(agi)} color="a"/>
        <div className="div"/>
        <TR label={d.itemize ? "− Itemized Deductions" : `− Standard Deduction (${d.filingStatus})`} value={`(${fmt(ded)})`} color="g"/>
        {d.itemize && ded > stdDed && <TR label="  (Standard would be)" value={fmt(stdDed)} sub color=""/>}
        <TR label="= Federal Taxable Income" value={fmt(taxable)} color="r"/>
        <div className="fn">AGI = Gross − above-the-line deductions. Taxable Income = AGI − Standard/Itemized Deduction. Student loan interest deduction capped at $2,500 and phases out at higher incomes.</div>
      </div>
      <div className="card">
        <div className="card-t">Tax Calculation</div><div className="card-s">All components</div>
        <TR label="Federal Income Tax (brackets)" value={fmt(fedTax)} color="r"/>
        <TR label="  — Social Security (6.2% up to $176,100)" value={fmt(fica.ss)} sub/>
        <TR label="  — Medicare (1.45% all wages)" value={fmt(fica.med)} sub/>
        {fica.addl > 0 && <TR label="  — Additional Medicare (0.9% over threshold)" value={fmt(fica.addl)} sub/>}
        <TR label="FICA Total" value={fmt(fica.total)} color="r"/>
        <TR label={`State Tax (${d.stateRate}% × AGI)`} value={fmt(stateTax)} color="r"/>
        {credits > 0 && <TR label="− Tax Credits" value={`(${fmt(credits)})`} color="g"/>}
        <TR label="Ordinary Income Tax Total" value={fmt(totalTax)} color="" total/>
        <div className="div"/>
        <TR label={`Long-Term Capital Gains Tax (${fmt(ltGain)} gains)`} value={fmt(ltTax)} color="a"/>
        {stGain > 0 && <TR label={`Short-Term Capital Gains (${fmt(stGain)} × ${pct(marginal)})`} value={fmt(stTax)} color="r"/>}
        {niitTax > 0 && <TR label="Net Investment Income Tax (3.8%)" value={fmt(niitTax)} color="a"/>}
        <TR label="TOTAL ESTIMATED TAX BILL" value={fmt(totalWithInvest)} color="r" total/>
        <div style={{ display: "flex", gap: 10, marginTop: 12 }}>
          {[["Effective Rate", pct(gross > 0 ? totalWithInvest / gross : 0), "var(--green)"], ["Marginal Rate", pct(marginal), "var(--amber)"]].map(([l, v, c]) =>
            <div key={l} style={{ flex: 1, background: "var(--surface2)", borderRadius: 8, padding: "10px 13px" }}>
              <div style={{ fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: "0.07em", fontWeight: 700, marginBottom: 3 }}>{l}</div>
              <div style={{ fontFamily: "var(--font-d)", fontSize: 18, color: c, fontWeight: 700 }}>{v}</div>
            </div>
          )}
        </div>
        <div className="fn">Federal tax: progressive brackets (2026 rates). FICA SS: 6.2% × min(wages, $176,100). Medicare: 1.45% × wages. Additional Medicare: 0.9% on wages over $200k (single). State: flat rate × AGI (estimate only). LTCG uses stacking method — gains taxed at preferential rates applied on top of ordinary income.</div>
      </div>
    </div>
    <div className="card">
      <div className="card-t">2026 Federal Tax Brackets — {d.filingStatus === "married" ? "MFJ" : d.filingStatus === "hoh" ? "Head of Household" : "Single"}</div>
      <div className="card-s">Your income falls here (highlighted)</div>
      <table className="tbl"><thead><tr><th>Rate</th><th>Income Range</th><th className="r">Your Income in Bracket</th><th className="r">Tax Owed in Bracket</th><th className="r">Cumulative Tax</th></tr></thead>
        <tbody>{(BRACKETS[d.filingStatus] || BRACKETS.single).reduce((acc, [lim, rate], i, arr) => {
          const low = i === 0 ? 0 : arr[i-1][0];
          const inBracket = Math.max(0, Math.min(taxable, lim) - low);
          const taxInBracket = inBracket * rate;
          acc.cumTax = (acc.cumTax || 0) + taxInBracket;
          const active = inBracket > 0;
          acc.rows.push(<tr key={i} style={{ background: active ? "var(--green-bg)" : "", fontWeight: active ? 600 : "" }}>
            <td><span className={`badge ${rate >= 0.32 ? "br" : rate >= 0.22 ? "ba" : "bg"}`}>{pct(rate, 0)}</span></td>
            <td style={{ fontSize: 11, color: "var(--text2)" }}>{fmt(low)} – {lim === Infinity ? "∞" : fmt(lim)}</td>
            <td className="r">{inBracket > 0 ? fmt(inBracket) : "—"}</td>
            <td className="r" style={{ color: taxInBracket > 0 ? "var(--red)" : "var(--text3)" }}>{taxInBracket > 0 ? fmt(taxInBracket) : "—"}</td>
            <td className="r">{taxInBracket > 0 ? fmt(acc.cumTax) : "—"}</td>
          </tr>);
          return acc;
        }, { rows: [], cumTax: 0 }).rows}</tbody>
      </table>
      <div className="fn">Only income within each bracket is taxed at that rate. Example: if taxable income = $50,000 (single), the first $11,925 is taxed at 10%, the next $36,550 at 12%. The "marginal rate" is only on the last dollar — not your whole income.</div>
    </div>
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// INVESTMENTS TAB (condensed but complete)
// ─────────────────────────────────────────────────────────────────────────────
async function fetchQ(ticker, key) {
  if (!key || !ticker) return null;
  try {
    const r = await fetch(`https://finnhub.io/api/v1/quote?symbol=${ticker.toUpperCase()}&token=${key}`);
    const d = await r.json();
    return d.c > 0 ? { price: d.c, change: d.d, pct: d.dp } : null;
  } catch { return null; }
}

const RP = [{ l:"Conservative",r:5,v:8},{ l:"Moderate",r:7,v:12},{ l:"Growth",r:9,v:16},{ l:"Aggressive",r:12,v:22}];

function InvestmentsTab({ d, upd, prices, setPrices, budget }) {
  const [sub, setSub] = useState("accounts");
  const [loading, setLoading] = useState(false);
  const idR = useRef(200);
  const nid = () => `h${++idR.current}`;
  const getP = h => prices[h.ticker?.toUpperCase()]?.price || num(h.price);
  const allH = d.accounts.flatMap((a, ai) => a.holdings.map(hld => ({ ...hld, acctName: a.name, acctType: a.type, ai })));
  const totPort = allH.reduce((s, h) => s + num(h.shares) * getP(h), 0);
  const totCost = allH.reduce((s, h) => s + num(h.shares) * num(h.cost), 0);
  const totDivs = allH.reduce((s, h) => s + num(h.shares) * num(h.div), 0);
  const wRet = totPort > 0 ? allH.reduce((s, h) => { const mv = num(h.shares) * getP(h); return s + (mv / totPort) * num(h.expRet); }, 0) : 0;
  const portVol = totPort > 0 ? Math.sqrt(allH.reduce((s, h) => { const w = num(h.shares) * getP(h) / totPort; return s + Math.pow(w * (num(h.vol) || 15), 2); }, 0)) : 0;
  const RF = 4.3;
  const sharpe = portVol > 0 ? (wRet - RF) / portVol : 0;
  const retVal = d.accounts.filter(a => TAX_ADV.includes(a.type)).flatMap(a => a.holdings).reduce((s, h) => s + num(h.shares) * getP(h), 0);
  const taxVal = totPort - retVal;
  const yrs = Math.max(1, d.retireAge - d.age);
  const rp = RP[d.riskProfile || 1];
  const retContrib = Object.values(d.retirement).reduce((s, v) => s + num(v), 0) * 12;
  const retProj = Array.from({ length: yrs + 1 }, (_, i) => fvLump(retVal, rp.r / 100, i) + fvAnnuity(retContrib, rp.r / 100, i));

  const ltGain = d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings).filter(h => h.gainType === "long").reduce((s, h) => s + Math.max(0, num(h.shares) * getP(h) - num(h.shares) * num(h.cost)), 0);
  const stGain = d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings).filter(h => h.gainType === "short").reduce((s, h) => s + Math.max(0, num(h.shares) * getP(h) - num(h.shares) * num(h.cost)), 0);
  const ltTax = calcLTCGTax(ltGain, budget.taxable, d.filingStatus);
  const stTax = stGain * budget.marginal;

  const refresh = async () => {
    if (!d.finnhubKey) return;
    setLoading(true);
    const tickers = [...new Set(allH.map(hld => hld.ticker?.toUpperCase()).filter(Boolean))];
    const res = {};
    for (const t of tickers) { const q = await fetchQ(t, d.finnhubKey); if (q) res[t] = q; }
    setPrices(res); setLoading(false);
  };

  const addA = () => upd({ accounts: [...d.accounts, { id: `a${Date.now()}`, name: "New Account", type: "Taxable Brokerage", holdings: [] }] });
  const updA = (id, f, v) => upd({ accounts: d.accounts.map(a => a.id === id ? { ...a, [f]: v } : a) });
  const delA = id => upd({ accounts: d.accounts.filter(a => a.id !== id) });
  const addH = aid => upd({ accounts: d.accounts.map(a => a.id === aid ? { ...a, holdings: [...a.holdings, { id: nid(), ticker: "", name: "", shares: "", price: "", cost: "", div: "", expRet: "8", vol: "15", gainType: "long" }] } : a) });
  const updH = (aid, hid, f, v) => upd({ accounts: d.accounts.map(a => a.id === aid ? { ...a, holdings: a.holdings.map(hld => hld.id === hid ? { ...hld, [f]: v } : hld) } : a) });
  const delH = (aid, hid) => upd({ accounts: d.accounts.map(a => a.id === aid ? { ...a, holdings: a.holdings.filter(h => h.id !== hid) } : a) });

  return <div className="stack fu">
    <div className="stabs">{[["accounts","Accounts"],["combined","Combined View"],["retirement","Retirement Projection"],["gains","Taxable Gains & Tax"],["insights","Insights"]].map(([id,l]) => <button key={id} className={`stab${sub===id?" on":""}`} onClick={() => setSub(id)}>{l}</button>)}</div>
    <div className="card" style={{ padding: "11px 15px" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 10, flexWrap: "wrap" }}>
        <div className="field" style={{ flex: 1, minWidth: 180 }}>
          <label className="lbl">Finnhub API Key <span style={{ fontWeight: 400, textTransform: "none", fontSize: 9.5, color: "var(--text3)" }}>— free at finnhub.io, already pre-loaded</span></label>
          <input className="inp" type="password" value={d.finnhubKey} onChange={e => upd({ finnhubKey: e.target.value })} placeholder="pk_..."/>
        </div>
        <button className="btn btn-green" style={{ marginTop: 16, whiteSpace: "nowrap" }} onClick={refresh} disabled={!d.finnhubKey || loading}>{loading ? "⏳ Fetching..." : "🔄 Refresh Live Prices"}</button>
        {Object.keys(prices).length > 0 && <span style={{ fontSize: 10.5, color: "var(--green)", marginTop: 16 }}>✓ {Object.keys(prices).length} tickers live</span>}
      </div>
    </div>
    <div className="g4">
      <div className="stat"><div className="stat-bar" style={{ background: "var(--blue)" }}/><div className="stat-l">Total Portfolio</div><div className="stat-v">{fmt(totPort)}</div><div className="stat-m">{allH.length} holdings · {d.accounts.length} accounts</div></div>
      <div className="stat"><div className="stat-bar" style={{ background: totPort - totCost >= 0 ? "var(--green)" : "var(--red)" }}/><div className="stat-l">Total Gain / Loss</div><div className="stat-v" style={{ color: totPort - totCost >= 0 ? "var(--green)" : "var(--red)" }}>{fmt(totPort - totCost)}</div><div className={`stat-m ${totPort-totCost>=0?"up":"dn"}`}>{totCost > 0 ? pct((totPort - totCost) / totCost) : "—"} total return</div></div>
      <div className="stat"><div className="stat-bar" style={{ background: "var(--amber)" }}/><div className="stat-l">Annual Dividends <Tip k="divY"><span/></Tip></div><div className="stat-v">{fmt(totDivs)}</div><div className="stat-m">{fmt(totDivs / 12)}/mo · {totPort > 0 ? pct(totDivs / totPort) : "—"} yield</div></div>
      <div className="stat"><div className="stat-bar" style={{ background: sharpe >= 1 ? "var(--green)" : sharpe >= 0.5 ? "var(--amber)" : "var(--red)" }}/><div className="stat-l">Sharpe Ratio <Tip k="sharpe"><span/></Tip></div><div className="stat-v">{sharpe.toFixed(2)}</div><div className="stat-m">vs {RF}% risk-free <Tip k="rf"><span/></Tip></div></div>
    </div>

    {sub === "accounts" && <div className="stack">
      {d.accounts.map((a, ai) => {
        const ac = ACCT_COLORS[ai % ACCT_COLORS.length];
        const aVal = a.holdings.reduce((s, h) => s + num(h.shares) * getP(h), 0);
        const aCost = a.holdings.reduce((s, h) => s + num(h.shares) * num(h.cost), 0);
        const aGain = aVal - aCost;
        const taxAdv = TAX_ADV.includes(a.type);
        const isRoth = ROTH.includes(a.type);
        return <div className="card" key={a.id}>
          <div className="card-h">
            <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
              <div style={{ width: 3, height: 38, borderRadius: 2, background: ac }}/>
              <div>
                <input className="ti" style={{ fontFamily: "var(--font-d)", fontSize: 15, fontWeight: 700, display: "block", marginBottom: 2 }} value={a.name} onChange={e => updA(a.id, "name", e.target.value)}/>
                <div style={{ display: "flex", gap: 5, alignItems: "center" }}>
                  <select value={a.type} onChange={e => updA(a.id, "type", e.target.value)} style={{ background: "none", border: "none", color: "var(--text3)", fontSize: 10.5, fontFamily: "var(--font)", cursor: "pointer" }}>{ACCT_TYPES.map(t => <option key={t}>{t}</option>)}</select>
                  {taxAdv && <span className={`badge ${isRoth ? "bp" : "ba"}`}>{isRoth ? "Roth: Tax-Free Growth" : "Tax-Deferred"}</span>}
                </div>
              </div>
            </div>
            <div style={{ textAlign: "right" }}>
              <div style={{ fontFamily: "var(--font-d)", fontSize: 17, color: ac, fontWeight: 700 }}>{fmt(aVal)}</div>
              <div style={{ fontSize: 10.5, color: aGain >= 0 ? "var(--green)" : "var(--red)" }}>{aGain >= 0 ? "↑" : "↓"} {fmt(Math.abs(aGain))} · {aCost > 0 ? pct(aGain / aCost) : "—"}</div>
              {!taxAdv && <div style={{ fontSize: 9.5, color: "var(--text3)" }}>Est. LT cap gains tax if sold: ~{fmt(a.holdings.filter(h => h.gainType === "long").reduce((s, h) => s + Math.max(0, num(h.shares) * getP(h) - num(h.shares) * num(h.cost)), 0) * 0.15)}</div>}
              {isRoth && <div style={{ fontSize: 9.5, color: "var(--purple)" }}>No capital gains tax — Roth grows tax-free</div>}
              {taxAdv && !isRoth && <div style={{ fontSize: 9.5, color: "var(--amber)" }}>Withdrawals taxed as ordinary income</div>}
              <button className="btn-del" style={{ fontSize: 10, marginTop: 3 }} onClick={() => delA(a.id)}>Remove</button>
            </div>
          </div>
          <div style={{ overflowX: "auto" }}>
            <table className="tbl">
              <thead><tr><th>Ticker</th><th>Name</th><th className="r">Shares</th><th className="r">Price</th><th className="r">Cost/sh</th><th className="r">Value</th><th className="r">Gain</th><th className="r">Div/sh</th><th className="r">Exp Ret%</th><th className="r">Vol%</th><th>Hold Type</th><th></th></tr></thead>
              <tbody>{a.holdings.map(hld => {
                const lp = prices[hld.ticker?.toUpperCase()];
                const up = lp?.price || num(hld.price);
                const mv = num(hld.shares) * up, cost = num(hld.shares) * num(hld.cost), gain = mv - cost;
                return <tr key={hld.id}>
                  <td style={{ fontWeight: 700 }}><input className="ti" style={{ width: 54 }} value={hld.ticker} onChange={e => updH(a.id, hld.id, "ticker", e.target.value)} placeholder="VTI"/></td>
                  <td><input className="ti" style={{ width: 115 }} value={hld.name} onChange={e => updH(a.id, hld.id, "name", e.target.value)}/></td>
                  <td className="r"><input className="ti" type="number" style={{ width: 62, textAlign: "right" }} value={hld.shares} onChange={e => updH(a.id, hld.id, "shares", e.target.value)}/></td>
                  <td className="r"><div><input className="ti" type="number" style={{ width: 62, textAlign: "right" }} value={hld.price} onChange={e => updH(a.id, hld.id, "price", e.target.value)}/>{lp && <div style={{ fontSize: 9, color: "var(--green)" }}>Live ${lp.price.toFixed(2)}</div>}</div></td>
                  <td className="r"><input className="ti" type="number" style={{ width: 62, textAlign: "right" }} value={hld.cost} onChange={e => updH(a.id, hld.id, "cost", e.target.value)}/></td>
                  <td className="r" style={{ fontWeight: 700 }}>{fmt(mv)}</td>
                  <td className="r"><span style={{ color: gain >= 0 ? "var(--green)" : "var(--red)", fontWeight: 700 }}>{fmt(gain)}<br/><span style={{ fontSize: 9.5, opacity: 0.8 }}>({cost > 0 ? pct(gain / cost) : "—"})</span></span></td>
                  <td className="r"><input className="ti" type="number" style={{ width: 48, textAlign: "right" }} value={hld.div} onChange={e => updH(a.id, hld.id, "div", e.target.value)}/></td>
                  <td className="r"><input className="ti" type="number" style={{ width: 45, textAlign: "right" }} value={hld.expRet} onChange={e => updH(a.id, hld.id, "expRet", e.target.value)}/></td>
                  <td className="r"><input className="ti" type="number" style={{ width: 45, textAlign: "right" }} value={hld.vol} onChange={e => updH(a.id, hld.id, "vol", e.target.value)}/></td>
                  <td><select value={hld.gainType} onChange={e => updH(a.id, hld.id, "gainType", e.target.value)} style={{ background: "none", border: "none", color: "var(--text3)", fontSize: 10, fontFamily: "var(--font)" }}><option value="long">Long (&gt;12mo)</option><option value="short">Short (&lt;12mo)</option></select></td>
                  <td><button className="btn-del" onClick={() => delH(a.id, hld.id)}>✕</button></td>
                </tr>;
              })}</tbody>
            </table>
          </div>
          <button className="btn-add" style={{ marginTop: 7 }} onClick={() => addH(a.id)}>+ Add Holding to {a.name}</button>
        </div>;
      })}
      <button className="btn-add" onClick={addA}>+ Add Account (Brokerage, IRA, 401k…)</button>
      <div className="fn">Portfolio Volatility = √(Σ(weight × volatility)²) — simplified assuming zero covariance (conservative). Sharpe Ratio = (Weighted Return − {RF}%) ÷ Portfolio Volatility. Weighted return = Σ(holding weight × expected return). These are estimates based on your inputs, not historical data.</div>
    </div>}

    {sub === "combined" && <div className="stack">
      <div className="g2">
        <div className="card"><div className="card-t">Portfolio by Account</div><div className="card-s">Value distribution</div><Donut size={140} stroke={26} slices={d.accounts.map((a, i) => ({ label: a.name, value: a.holdings.reduce((s, h) => s + num(h.shares) * getP(h), 0), color: ACCT_COLORS[i % ACCT_COLORS.length] }))}/></div>
        <div className="card"><div className="card-t">Risk Metrics</div><div className="card-s">Combined portfolio</div>
          {[["Weighted Avg Return", `${wRet.toFixed(1)}%`, "var(--green)", "divY"],["Portfolio Volatility", `${portVol.toFixed(1)}%`, "var(--amber)", "vol"],["Sharpe Ratio", sharpe.toFixed(2), sharpe >= 1 ? "var(--green)" : sharpe >= 0.5 ? "var(--amber)" : "var(--red)", "sharpe"],["Taxable Account Value", fmt(taxVal), "var(--blue)", "ltcg"],["Retirement Account Value", fmt(retVal), "var(--teal)", "safe4"],["Annual Dividends", fmt(totDivs), "var(--amber)", "divY"]].map(([l, v, c, t]) =>
            <div key={l} style={{ display: "flex", justifyContent: "space-between", paddingBottom: 9, borderBottom: "1px solid var(--border)" }}>
              <span style={{ fontSize: 12, color: "var(--text2)" }}><Tip k={t}>{l + " "}</Tip></span>
              <span style={{ fontFamily: "var(--font-d)", fontSize: 13, color: c, fontWeight: 700 }}>{v}</span>
            </div>
          )}
        </div>
      </div>
      <div className="card"><div className="card-t">All Holdings — Sorted by Value</div><div className="card-s">Combined across all accounts</div>
        <div style={{ overflowX: "auto" }}><table className="tbl"><thead><tr><th>Ticker</th><th>Name</th><th>Account</th><th>Tax Status</th><th className="r">Value</th><th className="r">Gain</th><th className="r">Ann. Div</th><th className="r">Weight</th></tr></thead>
          <tbody>{[...allH].sort((a, b) => num(b.shares) * getP(b) - num(a.shares) * getP(a)).map(hld => {
            const mv = num(hld.shares) * getP(hld), cost = num(hld.shares) * num(hld.cost), gain = mv - cost;
            const isTA = TAX_ADV.includes(hld.acctType);
            const isR = ROTH.includes(hld.acctType);
            return <tr key={hld.id + hld.acctName}>
              <td style={{ fontWeight: 700 }}>{hld.ticker || "—"}</td><td style={{ fontSize: 11 }}>{hld.name}</td>
              <td><span style={{ fontSize: 9.5, background: "var(--surface3)", borderRadius: 99, padding: "1px 7px", fontWeight: 700 }}>{hld.acctName}</span></td>
              <td><span className={`badge ${isTA ? (isR ? "bp" : "ba") : "bb"}`}>{isTA ? (isR ? "Roth" : "Tax-Deferred") : "Taxable"}</span></td>
              <td className="r" style={{ fontWeight: 700 }}>{fmt(mv)}</td>
              <td className="r"><span style={{ color: gain >= 0 ? "var(--green)" : "var(--red)" }}>{fmt(gain)}</span></td>
              <td className="r">{fmt(num(hld.shares) * num(hld.div))}</td>
              <td className="r">{totPort > 0 ? pct(mv / totPort) : "—"}</td>
            </tr>;
          })}</tbody>
        </table></div>
      </div>
    </div>}

    {sub === "retirement" && <div className="stack">
      <div className="g2">
        <div className="card"><div className="card-t">Retirement Settings</div>
          <div className="frow" style={{ marginBottom: 12 }}>
            <div className="field"><label className="lbl">Current Age</label><input className="inp" type="number" value={d.age} onChange={e => upd({ age: num(e.target.value) })}/></div>
            <div className="field"><label className="lbl">Target Retirement Age</label><input className="inp" type="number" value={d.retireAge} onChange={e => upd({ retireAge: num(e.target.value) })}/></div>
          </div>
          <div style={{ display: "flex", gap: 7, flexWrap: "wrap", marginBottom: 14 }}>
            {RP.map((p, i) => <button key={i} onClick={() => upd({ riskProfile: i })} style={{ padding: "4px 11px", borderRadius: 999, border: `1.5px solid ${d.riskProfile === i ? "var(--green)" : "var(--border)"}`, background: d.riskProfile === i ? "var(--green-bg)" : "none", color: d.riskProfile === i ? "var(--green)" : "var(--text2)", fontSize: 10.5, fontWeight: 700, fontFamily: "var(--font)" }}>{p.l} {p.r}%</button>)}
          </div>
          <div className="ins g"><div className="ins-l">Roth vs. Traditional <Tip k="roth"><span/></Tip></div>
            <p>Roth ({fmt(d.accounts.filter(a => ROTH.includes(a.type)).flatMap(a => a.holdings).reduce((s, h) => s + num(h.shares) * getP(h), 0))}): tax-free growth. Traditional ({fmt(d.accounts.filter(a => TAX_ADV.includes(a.type) && !ROTH.includes(a.type)).flatMap(a => a.holdings).reduce((s, h) => s + num(h.shares) * getP(h), 0))}): taxed on withdrawal as ordinary income.</p>
          </div>
        </div>
        <div className="card"><div className="card-t">Retirement Projection</div><div className="card-s">Age {d.retireAge} · {rp.l} ({rp.r}% growth)</div>
          <Spark data={retProj} color="var(--purple)" ht={90}/>
          <div style={{ display: "flex", justifyContent: "space-between", margin: "6px 0 12px" }}>
            <span style={{ fontSize: 10.5, color: "var(--text3)" }}>Today: {fmt(retVal)}</span>
            <span style={{ fontSize: 10.5, color: "var(--purple)", fontWeight: 700 }}>Age {d.retireAge}: {fmt(retProj[yrs])}</span>
          </div>
          <div className="ins g"><div className="ins-l">4% Withdrawal Rule <Tip k="safe4"><span/></Tip></div><p>{fmt(retProj[yrs] * 0.04)}/yr · {fmt(retProj[yrs] * 0.04 / 12)}/mo</p></div>
          <div className="fn">FV = PV × (1+r)^n + PMT × ((1+r)^n − 1) / r. PV = current retirement account balances. PMT = annual retirement contributions. r = {rp.r}%/yr. n = {yrs} years. Assumes constant rate — actual returns will vary.</div>
        </div>
      </div>
    </div>}

    {sub === "gains" && <div className="stack">
      <div className="ins b"><div className="ins-l">ℹ Retirement accounts (401k, IRA, Roth) have NO capital gains tax</div><p>Gains inside retirement accounts grow tax-deferred (traditional) or tax-free (Roth). Capital gains tax only applies to <strong>taxable brokerage accounts</strong>. The table below shows taxable positions only.</p></div>
      <div className="g2">
        {[["Long-Term Gains","var(--green-bg)","var(--green-light)","var(--green)",ltGain,ltTax,"ltcg","Held 12+ months. Tax: 0%, 15%, or 20% based on income."],
          ["Short-Term Gains","var(--amber-bg)","var(--amber-light)","var(--amber)",stGain,stTax,"stcg","Held <12 months. Taxed at your marginal income rate."]].map(([title,bg,brd,c,gain,tax,tip,desc]) =>
          <div key={title} style={{ background: bg, border: `1px solid ${brd}`, borderRadius: "var(--r)", padding: "16px 18px" }}>
            <div style={{ fontSize: 9.5, color: c, textTransform: "uppercase", letterSpacing: "0.08em", fontWeight: 800, marginBottom: 5 }}><Tip k={tip}>{title + " "}</Tip></div>
            <div style={{ fontFamily: "var(--font-d)", fontSize: 20, fontWeight: 700, marginBottom: 4 }}>{fmt(gain)}</div>
            <div style={{ fontSize: 12, color: "var(--text2)" }}>Est. tax if sold today: <strong style={{ color: "var(--red)" }}>{fmt(tax)}</strong></div>
            <div style={{ fontSize: 10.5, color: "var(--text3)", marginTop: 4 }}>{desc}</div>
          </div>
        )}
      </div>
      <div className="card"><div className="card-t">Taxable Holdings — Gain/Tax Detail</div><div className="card-s">Non-retirement accounts only</div>
        <table className="tbl"><thead><tr><th>Ticker</th><th>Account</th><th>Hold</th><th className="r">Gain/Loss</th><th className="r">Est. Tax</th><th className="r">After-Tax Value</th></tr></thead>
          <tbody>{d.accounts.filter(a => !TAX_ADV.includes(a.type)).flatMap(a => a.holdings.map(hld => ({ ...hld, acctName: a.name }))).map(hld => {
            const mv = num(hld.shares) * getP(hld), cost = num(hld.shares) * num(hld.cost), gain = mv - cost;
            const tax = gain > 0 ? (hld.gainType === "long" ? calcLTCGTax(gain, budget.taxable, d.filingStatus) : gain * budget.marginal) : 0;
            return <tr key={hld.id}><td style={{ fontWeight: 700 }}>{hld.ticker || "—"}</td><td style={{ fontSize: 11 }}>{hld.acctName}</td>
              <td><span className={`badge ${hld.gainType === "long" ? "bg" : "ba"}`}>{hld.gainType === "long" ? "Long" : "Short"}</span></td>
              <td className="r"><span style={{ color: gain >= 0 ? "var(--green)" : "var(--red)", fontWeight: 700 }}>{fmt(gain)}</span></td>
              <td className="r" style={{ color: "var(--red)" }}>{gain > 0 ? fmt(tax) : "—"}</td>
              <td className="r" style={{ color: "var(--green)", fontWeight: 700 }}>{fmt(mv - Math.max(0, tax))}</td>
            </tr>;
          })}</tbody>
        </table>
        <div className="fn">LTCG tax uses 2026 stacking method: gains are layered on top of ordinary income. The rate (0%, 15%, 20%) is determined by total income level. STCG = gain × marginal rate ({pct(budget.marginal)}). Tax estimates assume you sell all positions in the current tax year.</div>
      </div>
    </div>}

    {sub === "insights" && <div className="stack">
      {(() => {
        const ins = [];
        if (sharpe < 0.5 && totPort > 0) ins.push({ t: "a", title: "Low Sharpe Ratio", msg: `Sharpe of ${sharpe.toFixed(2)} means high risk relative to returns. Consider diversifying into lower-volatility assets like bond ETFs (BND, AGG).` });
        if (sharpe >= 1.5) ins.push({ t: "g", title: "Strong Risk-Adjusted Returns", msg: `Sharpe of ${sharpe.toFixed(2)} — generating solid returns per unit of risk.` });
        const top = allH.sort((a, b) => num(b.shares) * getP(b) - num(a.shares) * getP(a))[0];
        if (top && totPort > 0 && (num(top.shares) * getP(top)) / totPort > 0.4) ins.push({ t: "r", title: "Concentration Risk", msg: `${top.ticker} represents ${pct((num(top.shares) * getP(top)) / totPort)} of portfolio. High single-stock concentration amplifies risk.` });
        if (totDivs / Math.max(totPort, 1) < 0.01 && totPort > 0) ins.push({ t: "b", title: "Low Dividend Yield", msg: "Under 1% dividend yield. SCHD, VYM, or REITs could add meaningful passive income." });
        if (retVal < 50000 && yrs > 20) ins.push({ t: "g", title: "Compounding Power", msg: `${yrs} years until retirement. An extra $300/mo contributed now → ~${fmt(fvAnnuity(3600, 0.07, yrs))} more at retirement at 7%.` });
        if (ins.length === 0) ins.push({ t: "g", title: "Looking Good!", msg: "Portfolio appears well-balanced. Add more holdings for deeper analysis." });
        return ins.map((i, idx) => <div key={idx} className={`ins ${i.t}`}><div className="ins-l">{i.title}</div><p>{i.msg}</p></div>);
      })()}
    </div>}
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// NET WORTH TAB
// ─────────────────────────────────────────────────────────────────────────────
function NetWorthTab({ d, budget, prices, inflOn, inflRate }) {
  const getP = h => prices[h.ticker?.toUpperCase()]?.price || num(h.price);
  const allH = d.accounts.flatMap(a => a.holdings);
  const totPort = allH.reduce((s, h) => s + num(h.shares) * getP(h), 0);
  const retVal = d.accounts.filter(a => TAX_ADV.includes(a.type)).flatMap(a => a.holdings).reduce((s, h) => s + num(h.shares) * getP(h), 0);
  const taxVal = totPort - retVal;
  const cash = num(d.checkingBal) + num(d.savingsBal) + num(d.emergencyFund);
  const totLiab = d.liabilities.reduce((s, l) => s + num(l.balance), 0);
  const nomNW = totPort + cash - totLiab;
  const projRows = buildProjection({ budget, d, prices, inflRate, years: 30 });
  const nomProj = projRows.map(r => r.nominalNW);
  const realProj = projRows.map(r => r.realNW);

  return <div className="stack fu">
    <div className="g4">
      {[["Net Worth", nomNW, inflOn ? real(nomNW, inflRate/100, 0) : null, "Assets − Liabilities", "var(--green)"],
        ["Total Assets", totPort + cash, null, `Portfolio + Cash`, "var(--blue)"],
        ["Total Liabilities", totLiab, null, `${d.liabilities.length} debts`, "var(--red)"],
        ["Debt-to-Asset Ratio", null, null, null, "var(--amber)"]].map(([l, v, rl, m, c], i) =>
        <div key={l} className="stat">
          <div className="stat-bar" style={{ background: c }}/>
          <div className="stat-l">{l}</div>
          {i === 3
            ? <><div className="stat-v">{(totPort + cash) > 0 ? pct(totLiab / (totPort + cash)) : "—"}</div><div className={`stat-m ${totLiab / (totPort + cash) < 0.3 ? "up" : "dn"}`}>{totLiab / (totPort + cash) < 0.3 ? "Healthy" : "Monitor"}</div></>
            : <><div className="stat-v">{fmt(v)}</div>{inflOn && rl !== null && <div className="stat-v infl" style={{ fontSize: 13, marginBottom: 2 }}>{fmt(rl)} <span className="infl-badge">real</span></div>}<div className="stat-m">{m}</div></>}
        </div>
      )}
    </div>
    <div className="g2">
      <div className="card"><div className="card-t">Assets Breakdown</div><div className="card-s">Complete picture</div>
        <Donut ctr={fmt(totPort + cash)} sub="total assets" slices={[
          { label: "Taxable Investments", value: taxVal, color: "var(--blue)" },
          { label: "Retirement Accounts", value: retVal, color: "var(--purple)" },
          { label: "Checking", value: num(d.checkingBal), color: "var(--green)" },
          { label: "Savings / HYSA", value: num(d.savingsBal), color: "var(--teal)" },
          { label: "Emergency Fund", value: num(d.emergencyFund), color: "var(--amber)" },
        ].filter(s => s.value > 0)}/>
      </div>
      <div className="card">
        <div className="card-t">30-Year Net Worth{inflOn ? " — Nominal vs. Real" : ""}</div><div className="card-s">{inflOn ? `Inflation-adjusted at ${inflRate}%/yr` : "Nominal projection"}</div>
        <Spark data={nomProj} data2={inflOn ? realProj : null} ht={110}/>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 6 }}>
          <span style={{ fontSize: 10.5, color: "var(--text3)" }}>Today: {fmt(nomNW)}</span>
          <span style={{ fontSize: 10.5, color: "var(--green)", fontWeight: 700 }}>Yr 30: {fmt(nomProj[30])}</span>
        </div>
        {inflOn && <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 3 }}>
          <span style={{ fontSize: 10, color: "var(--purple)", fontWeight: 600 }}>Real Yr 30: {fmt(realProj[30])}</span>
        </div>}
        {inflOn && <div style={{ marginTop: 10, padding: "8px 12px", background: "var(--purple-bg)", borderRadius: 7, fontSize: 11, color: "var(--purple)" }}>
          💡 At {inflRate}%/yr inflation, {fmt(nomProj[30])} in 30 years has the purchasing power of {fmt(realProj[30])} today — about {pct(realProj[30]/nomProj[30])} of nominal value.
        </div>}
        <div className="fn">Nominal: future dollar value. Real: inflation-adjusted using formula Real = Nominal ÷ (1+{inflRate/100})^n. Projection compounds portfolio at weighted avg expected return, adds annual savings, and subtracts debt paydown.</div>
      </div>
    </div>
    <div className="card"><div className="card-t">Debt Payoff Analysis</div><div className="card-s">Payoff timeline and total interest</div>
      {d.liabilities.length === 0
        ? <div style={{ color: "var(--text3)", fontSize: 12, textAlign: "center", padding: 20 }}>No liabilities — add them in the Budget tab.</div>
        : <table className="tbl"><thead><tr><th>Debt</th><th className="r">Balance</th><th className="r">Rate</th><th className="r">Payment</th><th className="r">Payoff Year</th><th className="r">Total Interest</th></tr></thead>
          <tbody>{d.liabilities.map(l => {
            const bal = num(l.balance), rate = num(l.rate) / 100 / 12, pmt = num(l.payment);
            // Months to payoff: n = -ln(1 - bal*rate/pmt) / ln(1+rate)
            const mos = rate > 0 && pmt > bal * rate ? -Math.log(1 - bal * rate / pmt) / Math.log(1 + rate) : pmt > 0 ? bal / pmt : 0;
            const yr = new Date().getFullYear() + Math.ceil(mos / 12);
            const interest = pmt * mos - bal;
            return <tr key={l.id}><td style={{ fontWeight: 600 }}>{l.label}</td>
              <td className="r" style={{ color: "var(--red)", fontWeight: 700 }}>{fmt(bal)}</td>
              <td className="r">{num(l.rate).toFixed(1)}%</td>
              <td className="r">{fmt(pmt)}/mo</td>
              <td className="r">{mos > 0 ? yr : "—"}</td>
              <td className="r" style={{ color: "var(--amber)" }}>{interest > 0 ? fmt(interest) : "—"}</td>
            </tr>;
          })}</tbody>
        </table>}
      <div className="fn">Payoff months = −ln(1 − balance × monthlyRate ÷ payment) ÷ ln(1 + monthlyRate). Total interest = (payment × months) − original balance. This assumes fixed rate and no extra payments.</div>
    </div>
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// LIFE TIMELINE TAB — visual milestone map with net worth impact
// ─────────────────────────────────────────────────────────────────────────────
function TimelineTab({ d, upd, budget, prices, inflOn, inflRate }) {
  const [view, setView] = useState("map"); // "map" | "table" | "edit"
  const idR = useRef(300);
  const nid = () => ++idR.current;
  const curYear = new Date().getFullYear();

  const projRows = buildProjection({ budget, d, prices, inflRate, years: 40 });
  const sorted = [...d.timeline].sort((a, b) => Number(a.year) - Number(b.year));

  return <div className="stack fu">
    <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 10 }}>
      <div>
        <div style={{ fontFamily: "var(--font-d)", fontSize: 18, color: "var(--text)" }}>Life Timeline & Net Worth Map</div>
        <div style={{ fontSize: 11, color: "var(--text3)", marginTop: 2 }}>Visualize how milestones impact your net worth over time</div>
      </div>
      <div style={{ display: "flex", gap: 7 }}>
        {[["map","🗺 Visual Map"],["table","📋 Data Table"],["edit","✏️ Edit"]].map(([id, l]) =>
          <button key={id} className={`stab${view === id ? " on" : ""}`} onClick={() => setView(id)}>{l}</button>
        )}
      </div>
    </div>

    {view === "map" && <>
      <div className="ins b"><div className="ins-l">How to read this</div><p>Each card shows a life milestone, its one-time cost, and the monthly spending change it triggers. Net worth shown is the projected value at that point. <strong>Solid line</strong> = nominal. {inflOn && <><strong>Dashed line</strong> = inflation-adjusted (real).</>} Drag events in Edit view to adjust timing.</p></div>

      {/* CHART: Net worth line with milestone markers */}
      <div className="card">
        <div className="card-t">Net Worth Over Time{inflOn ? " — Nominal vs. Real" : ""}</div>
        <div className="card-s">Including all milestone impacts · {inflOn ? `Real = inflation-adjusted at ${inflRate}%/yr` : "Nominal projection"}</div>
        <Spark data={projRows.map(r => r.nominalNW)} data2={inflOn ? projRows.map(r => r.realNW) : null} ht={120}/>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 6, flexWrap: "wrap", gap: 6 }}>
          <span style={{ fontSize: 10.5, color: "var(--text3)" }}>Age {d.age} (today): {fmt(projRows[0]?.nominalNW)}</span>
          <span style={{ fontSize: 10.5, color: "var(--green)", fontWeight: 700 }}>Age {d.age + 40}: {fmt(projRows[40]?.nominalNW)}</span>
        </div>
        {inflOn && <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 2 }}>
          <span style={{ fontSize: 10, color: "var(--purple)", fontWeight: 600 }}>Real (age {d.age+40}): {fmt(projRows[40]?.realNW)}</span>
        </div>}
        {/* Legend for milestones */}
        <div style={{ display: "flex", gap: 8, flexWrap: "wrap", marginTop: 12 }}>
          {sorted.map(m => {
            const yr = Number(m.year);
            const rowIdx = Math.min(yr - curYear, 40);
            const projRow = projRows[Math.max(0, rowIdx)];
            return <div key={m.id} style={{ display: "flex", alignItems: "center", gap: 4, background: "var(--surface2)", borderRadius: 6, padding: "3px 8px" }}>
              <span style={{ fontSize: 12 }}>{MI_ICON[m.cat] || "📌"}</span>
              <span style={{ fontSize: 10, color: "var(--text2)", fontWeight: 600 }}>{m.year}: {m.label}</span>
              {projRow && <span style={{ fontSize: 10, color: "var(--green)", fontWeight: 700, marginLeft: 4 }}>{fmt(projRow.nominalNW)}</span>}
            </div>;
          })}
        </div>
        <div className="fn">Net worth at each point = Portfolio Value + Cash − Remaining Liabilities. Portfolio grows at weighted avg return of your holdings. One-time costs reduce portfolio in the year they occur. Monthly delta changes the annual savings added to portfolio thereafter. Formula: NW(n) = Portfolio(n) + Cash − Liabilities(n). Portfolio(n) = Portfolio(n-1) × (1+r) + Annual Savings. Liability(n) = max(0, Liability(n-1) × (1+monthlyRate)^12 − Annual Payments).</div>
      </div>

      {/* VISUAL MILESTONE CARDS */}
      <div className="vtl">
        {sorted.map((m, idx) => {
          const yr = Number(m.year);
          const rowIdx = Math.min(Math.max(yr - curYear, 0), 40);
          const projRow = projRows[rowIdx];
          const prevRow = rowIdx > 0 ? projRows[rowIdx - 1] : projRows[0];
          const nwDelta = projRow && prevRow ? projRow.nominalNW - prevRow.nominalNW : 0;
          const isPast = yr <= curYear;
          const isNext = yr === sorted[0]?.year;
          return <div key={m.id} className="vtl-item">
            <div className="vtl-left">
              <div className="vtl-yr">{m.year}</div>
              <div className="vtl-icon-wrap" style={{ background: MI_COLOR[m.cat] || "var(--text2)" }}>
                <span>{MI_ICON[m.cat] || "📌"}</span>
              </div>
              {idx < sorted.length - 1 && <div className="vtl-connector"/>}
            </div>
            <div className="vtl-body">
              <div className={`vtl-card${isNext && !isPast ? " highlight" : ""}`}>
                <div className="vtl-name">
                  {m.label}
                  {isPast && <span className="badge ba">Past</span>}
                  {!isPast && yr - curYear <= 2 && <span className="badge bg">Soon</span>}
                  <span style={{ fontSize: 11, color: "var(--text3)", fontWeight: 400 }}>Age {d.age + (yr - curYear)}</span>
                </div>
                <div className="vtl-row">
                  {num(m.cost) > 0 && <span className="vtl-chip br" style={{ background: "var(--red-bg)" }}>
                    💸 One-time cost: {fmt(num(m.cost))}
                  </span>}
                  {num(m.monthlyDelta) !== 0 && <span className={`vtl-chip ${num(m.monthlyDelta) > 0 ? "br" : "bg"}`} style={{ background: num(m.monthlyDelta) > 0 ? "var(--amber-bg)" : "var(--green-bg)" }}>
                    {num(m.monthlyDelta) > 0 ? "↑" : "↓"} Monthly spending: {num(m.monthlyDelta) > 0 ? "+" : ""}{fmt(num(m.monthlyDelta))}/mo
                  </span>}
                  {num(m.cost) === 0 && num(m.monthlyDelta) === 0 && <span className="vtl-chip bb" style={{ background: "var(--blue-bg)", color: "var(--blue)" }}>No financial impact entered</span>}
                </div>
                {projRow && <div className="vtl-impact">
                  <div style={{ display: "flex", gap: 16, flexWrap: "wrap" }}>
                    <div><span style={{ fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: "0.07em", fontWeight: 700 }}>Projected Net Worth</span>
                      <div className="vtl-nw" style={{ color: projRow.nominalNW >= 0 ? "var(--green)" : "var(--red)" }}>{fmt(projRow.nominalNW)}</div>
                      {inflOn && <div className="vtl-nw-delta">Real: {fmt(projRow.realNW)}</div>}
                    </div>
                    <div><span style={{ fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: "0.07em", fontWeight: 700 }}>Monthly Savings at this point</span>
                      <div className="vtl-nw" style={{ color: projRow.effectiveMonthlySavings >= 0 ? "var(--green)" : "var(--red)" }}>{fmt(projRow.effectiveMonthlySavings)}/mo</div>
                    </div>
                    {num(m.cost) > 0 && <div><span style={{ fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: "0.07em", fontWeight: 700 }}>Net Worth Impact (this year)</span>
                      <div className="vtl-nw" style={{ color: nwDelta >= 0 ? "var(--green)" : "var(--red)" }}>{nwDelta >= 0 ? "+" : ""}{fmt(nwDelta)}</div>
                    </div>}
                  </div>
                </div>}
              </div>
            </div>
          </div>;
        })}
        {sorted.length === 0 && <div style={{ textAlign: "center", padding: 40, color: "var(--text3)" }}>No milestones yet. Switch to "Edit" to add your first life event.</div>}
      </div>
    </>}

    {view === "table" && <div className="card">
      <div className="card-t">Year-by-Year Projection</div><div className="card-s">Includes all milestone impacts</div>
      <div style={{ overflowX: "auto" }}>
        <table className="tbl"><thead><tr><th>Year</th><th>Age</th><th>Events</th><th className="r">Monthly Savings</th><th className="r">One-Time Costs</th><th className="r">Net Worth</th>{inflOn && <th className="r">Real Net Worth</th>}</tr></thead>
          <tbody>{projRows.filter((r, i) => i % 2 === 0 || r.newMilestones.length > 0).map((r, i) =>
            <tr key={i} style={{ background: r.newMilestones.length > 0 ? "var(--amber-bg)" : "" }}>
              <td style={{ fontWeight: 700 }}>{r.year}</td>
              <td style={{ color: "var(--text3)" }}>{r.age}</td>
              <td>{r.newMilestones.map(m => <span key={m.id} style={{ marginRight: 6, fontSize: 11 }}>{MI_ICON[m.cat] || "📌"} {m.label}</span>)}</td>
              <td className="r"><span style={{ color: r.effectiveMonthlySavings >= 0 ? "var(--green)" : "var(--red)", fontWeight: 600 }}>{fmt(r.effectiveMonthlySavings)}</span></td>
              <td className="r" style={{ color: "var(--red)" }}>{r.lumpCost > 0 ? `−${fmt(r.lumpCost)}` : "—"}</td>
              <td className="r"><span style={{ color: r.nominalNW >= 0 ? "var(--green)" : "var(--red)", fontWeight: 700 }}>{fmt(r.nominalNW)}</span></td>
              {inflOn && <td className="r"><span style={{ color: "var(--purple)", fontWeight: 600 }}>{fmt(r.realNW)}</span></td>}
            </tr>
          )}</tbody>
        </table>
      </div>
      <div className="fn">Monthly Savings = Base Annual Savings ÷ 12 + cumulative monthly deltas from all past milestones. Net Worth = Portfolio + Cash − Liabilities. One-time costs are subtracted from portfolio in the year they occur. {inflOn ? `Real = Nominal ÷ (1+${inflRate/100})^years.` : ""}</div>
    </div>}

    {view === "edit" && <div className="card">
      <div className="card-h">
        <div><div className="card-t">Edit Milestones</div><div className="card-s">Add life events and their financial impact</div></div>
        <button className="btn btn-ghost btn-sm" onClick={() => upd({ timeline: [...d.timeline, { id: nid(), year: curYear + 5, label: "New Event", cost: 0, monthlyDelta: 0, cat: "life" }] })}>+ Add Event</button>
      </div>
      <div className="ins b" style={{ marginBottom: 14 }}><div className="ins-l">How to use</div><p><strong>One-time cost:</strong> lump sum in that year (e.g. $60k home down payment). <strong>Monthly Δ:</strong> permanent change to monthly spending after this event (e.g. +$800 for mortgage over rent, +$1,400 for childcare). Use negative for reduced expenses (e.g. payoff auto loan frees up −$400/mo).</p></div>
      <div className="stack" style={{ gap: 9 }}>
        {sorted.map(m => <div key={m.id} style={{ display: "grid", gridTemplateColumns: "60px 1fr 90px 105px 90px 28px", gap: 8, alignItems: "end", padding: "10px 0", borderBottom: "1px solid var(--border)" }}>
          <div className="field"><label className="lbl">Year</label><input className="inp" type="number" value={m.year} onChange={e => upd({ timeline: d.timeline.map(x => x.id === m.id ? { ...x, year: e.target.value } : x) })}/></div>
          <div className="field"><label className="lbl">Event Name</label><input className="inp" value={m.label} onChange={e => upd({ timeline: d.timeline.map(x => x.id === m.id ? { ...x, label: e.target.value } : x) })}/></div>
          <div className="field"><label className="lbl">Category</label>
            <select className="inp" value={m.cat} onChange={e => upd({ timeline: d.timeline.map(x => x.id === m.id ? { ...x, cat: e.target.value } : x) })}>
              {MI_CATS.map(c => <option key={c}>{c}</option>)}
            </select>
          </div>
          <div className="field"><label className="lbl">One-Time Cost</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={m.cost} onChange={e => upd({ timeline: d.timeline.map(x => x.id === m.id ? { ...x, cost: e.target.value } : x) })}/></div></div>
          <div className="field"><label className="lbl">Monthly Δ (+/−)</label><div className="inp-p"><span className="inp-ps">$</span><input className="inp" type="number" value={m.monthlyDelta} onChange={e => upd({ timeline: d.timeline.map(x => x.id === m.id ? { ...x, monthlyDelta: e.target.value } : x) })}/></div></div>
          <button className="btn-del" onClick={() => upd({ timeline: d.timeline.filter(x => x.id !== m.id) })}>✕</button>
        </div>)}
      </div>
    </div>}
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// CHATBOT
// ─────────────────────────────────────────────────────────────────────────────
function Chatbot({ d, budget, prices }) {
  const [open, setOpen] = useState(false);
  const [msgs, setMsgs] = useState([{ role: "ai", text: `Hi ${d.name}! 👋 I'm your financial assistant — I can see all your data. Ask me anything: "Am I saving enough?", "How can I reduce taxes?", "What if I have kids in 2030?"\n\n⚠️ I provide general educational information only — not professional financial advice.` }]);
  const [inp, setInp] = useState("");
  const [loading, setLoading] = useState(false);
  const endRef = useRef(null);
  useEffect(() => { endRef.current?.scrollIntoView({ behavior: "smooth" }); }, [msgs]);

  const allH = d.accounts.flatMap(a => a.holdings);
  const totPort = allH.reduce((s, h) => s + num(h.shares) * (prices[h.ticker?.toUpperCase()]?.price || num(h.price)), 0);
  const ctx = `User financial snapshot:
- Name: ${d.name}, Age: ${d.age}, Filing: ${d.filingStatus}
- Gross income: ${fmt(budget.gross)}/yr, Bonus: ${fmt(num(d.bonus))}
- Net take-home: ${fmt(budget.netAnnual / 12)}/mo
- Annual savings: ${fmt(budget.annualSavings)} (${pct(budget.savingsRate)} savings rate)
- Tax bill: ${fmt(budget.totalTax)} | Effective: ${pct(budget.effective)} | Marginal: ${pct(budget.marginal)}
- Portfolio: ${fmt(totPort)} across ${d.accounts.length} accounts
- Retirement contributions: ${fmt(budget.retMonthly)}/mo to ${Object.entries(d.retirement).filter(([,v])=>num(v)>0).map(([k,v])=>`${k}:${fmt(num(v))}`).join(",")}
- Liabilities: ${fmt(d.liabilities.reduce((s,l)=>s+num(l.balance),0))} total
- Retire target: age ${d.retireAge}
- Monthly expenses: ${fmt(budget.expMonthly)}/mo
- Milestones: ${d.timeline.map(m=>`${m.year}: ${m.label}`).join(", ")}`;

  const send = async () => {
    if (!inp.trim() || loading) return;
    const q = inp.trim(); setInp("");
    setMsgs(m => [...m, { role: "user", text: q }, { role: "ai", text: "", loading: true }]);
    setLoading(true);
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ model: "claude-sonnet-4-20250514", max_tokens: 800, messages: [{ role: "user", content: `You are a financial education assistant inside a personal finance app. Be helpful, concise, and specific using the user's data. Always note you're providing general educational information, not personalized professional advice.\n\nUser data:\n${ctx}\n\nQuestion: ${q}` }] }),
      });
      const data = await res.json();
      const reply = data.content?.[0]?.text || "Couldn't process that — try again.";
      setMsgs(m => m.map((x, i) => i === m.length - 1 ? { role: "ai", text: reply } : x));
    } catch {
      setMsgs(m => m.map((x, i) => i === m.length - 1 ? { role: "ai", text: "Connection issue — please try again." } : x));
    }
    setLoading(false);
  };

  return <>
    <button className="chat-fab" onClick={() => setOpen(o => !o)} title="Ask your AI financial assistant">{open ? "✕" : "💬"}</button>
    {open && <div className="chat-panel">
      <div className="chat-head">
        <div className="chat-ht"><span style={{ background: "var(--green)", borderRadius: 4, padding: "1px 5px", fontSize: 9 }}>AI</span> Financial Assistant</div>
        <button className="chat-hc" onClick={() => setOpen(false)}>✕</button>
      </div>
      <div className="chat-msgs">
        {msgs.map((m, i) => <div key={i} className={`msg ${m.role}${m.loading ? " loading" : ""}`}>{m.loading ? "Thinking…" : m.text}</div>)}
        <div ref={endRef}/>
      </div>
      <div className="chat-inp-row">
        <input className="chat-inp" placeholder="Ask a question…" value={inp} onChange={e => setInp(e.target.value)} onKeyDown={e => e.key === "Enter" && send()} disabled={loading}/>
        <button className="chat-send" onClick={send} disabled={loading || !inp.trim()}>→</button>
      </div>
    </div>}
  </>;
}

// ─────────────────────────────────────────────────────────────────────────────
// SEARCH
// ─────────────────────────────────────────────────────────────────────────────
function buildIdx(d) {
  const items = [];
  d.accounts.forEach(a => {
    items.push({ title: a.name, sub: `${a.type} · ${fmt(a.holdings.reduce((s,h)=>s+num(h.shares)*num(h.price),0))}`, tab: "investments" });
    a.holdings.forEach(h => { if (h.ticker) items.push({ title: h.ticker, sub: `${h.name} · ${a.name} · ${fmt(num(h.shares)*num(h.price))}`, tab: "investments" }); });
  });
  d.expenses.forEach(e => items.push({ title: e.label, sub: `${EXPENSE_CATS.find(c=>c.id===e.cat)?.label||e.cat} · ${fmt(e.amount)}/mo`, tab: "budget" }));
  d.incomes.forEach(i => items.push({ title: i.label, sub: `Income · ${fmt(i.amount)}/yr`, tab: "budget" }));
  d.liabilities.forEach(l => items.push({ title: l.label, sub: `Debt · ${fmt(l.balance)}`, tab: "networth" }));
  d.timeline.forEach(m => items.push({ title: m.label, sub: `${m.year} · ${m.cat}`, tab: "timeline" }));
  return items;
}
function SearchBar({ d, setTab }) {
  const [q, setQ] = useState(""), [show, setShow] = useState(false);
  const ref = useRef(null);
  useEffect(() => {
    const handler = e => { if (ref.current && !ref.current.contains(e.target)) setShow(false); };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, []);
  const idx = useMemo(() => buildIdx(d), [d]);
  const results = q.length > 1 ? idx.filter(i => i.title.toLowerCase().includes(q.toLowerCase()) || i.sub.toLowerCase().includes(q.toLowerCase())).slice(0, 8) : [];
  return <div className="sw" ref={ref}>
    <span className="sico">🔍</span>
    <input className="si" placeholder="Search holdings, expenses…" value={q} onChange={e => { setQ(e.target.value); setShow(true); }} onFocus={() => setShow(true)}/>
    {show && results.length > 0 && <div className="sr">
      {results.map((r, i) => <div key={i} className="sri" onClick={() => { setTab(r.tab); setShow(false); setQ(""); }}>
        <div className="sri-t">{r.title}</div><div className="sri-s">{r.sub}</div>
      </div>)}
    </div>}
  </div>;
}

// ─────────────────────────────────────────────────────────────────────────────
// APP ROOT
// ─────────────────────────────────────────────────────────────────────────────
const TABS = [
  { id: "overview", icon: "📊", label: "Overview" },
  { id: "budget", icon: "💰", label: "Budget" },
  { id: "taxes", icon: "📋", label: "Taxes 2026" },
  { id: "investments", icon: "📈", label: "Investments" },
  { id: "networth", icon: "💎", label: "Net Worth" },
  { id: "timeline", icon: "🗺", label: "Life Timeline" },
];

export default function App() {
  const [profile, setProfile] = useState(null);
  const [tab, setTab] = useState("overview");
  const [prices, setPrices] = useState({});
  const [inflOn, setInflOn] = useState(false);

  useEffect(() => {
    const last = localStorage.getItem("sf_v4_last");
    if (last) { const ps = loadP(); if (ps[last]) setProfile(ps[last]); }
  }, []);

  const login = p => { setProfile(p); localStorage.setItem("sf_v4_last", p.id); };
  const logout = () => { setProfile(null); localStorage.removeItem("sf_v4_last"); };
  const upd = useCallback(patch => {
    setProfile(prev => {
      const next = { ...prev, data: { ...prev.data, ...patch } };
      const ps = loadP(); ps[prev.id] = next; saveP(ps);
      return next;
    });
  }, []);

  const d = profile?.data;
  const budget = useMemo(() => d ? calcBudget(d) : {
    w2:0,se:0,passive:0,gross:0,pre401k:0,tradIRA:0,hsaDed:0,seDed:0,slIntDed:0,
    agi:0,stdDed:15000,itemDed:0,ded:15000,credits:0,taxable:0,
    fedTax:0,fica:{ss:0,med:0,addl:0,total:0},stateTax:0,totalTax:0,
    netAnnual:0,retMonthly:0,expMonthly:0,debtPayments:0,annualSavings:0,savingsRate:0,
    marginal:0.22,effective:0,rothContribs:0,
  }, [d?.incomes,d?.bonus,d?.retirement,d?.filingStatus,d?.stateRate,d?.expenses,d?.itemize,d?.deductions,d?.credits,d?.liabilities]);

  const inflRate = num(d?.inflationRate || 3);

  if (!profile) return <><style>{CSS}</style><AuthScreen onLogin={login}/></>;

  const PAGE_TITLES = { overview:"Overview", budget:"Budget & Expenses", taxes:"Tax Estimator — 2026", investments:"Investments", networth:"Net Worth", timeline:"Life Timeline" };

  return <><style>{CSS}</style>
    <div className="shell">
      <aside className="sidebar">
        <div className="sb-brand"><div className="sb-name">SimpliFinance</div><div className="sb-tag">Your financial OS</div></div>
        <nav className="sb-nav">
          <div className="sb-sec">Dashboard</div>
          {TABS.map(t => <button key={t.id} className={`ni${tab === t.id ? " on" : ""}`} onClick={() => setTab(t.id)}><span className="ni-ico">{t.icon}</span>{t.label}</button>)}
        </nav>
        <div className="sb-foot">
          <div className="user-row" onClick={logout} title="Sign out">
            <div className="uav">{d.name[0].toUpperCase()}</div>
            <div><div className="uname">{d.name}</div><div className="uhint">Click to sign out</div></div>
          </div>
        </div>
      </aside>
      <div className="content">
        <div className="topbar">
          <div className="tb-title">{PAGE_TITLES[tab]}</div>
          {/* INFLATION TOGGLE */}
          <button className={`inf-tog${inflOn ? " on" : ""}`} onClick={() => setInflOn(v => !v)} title="Toggle inflation-adjusted view">
            <span className="inf-tog-dot"/>
            {inflOn ? `Inflation ON (${inflRate}%)` : "Inflation Adjust"}
          </button>
          {inflOn && <div className="field" style={{ width: 80 }}>
            <div className="inp-p"><span className="inp-ps" style={{ color: "var(--purple)", fontWeight: 700 }}>%</span>
              <input className="inp" type="number" value={d.inflationRate || 3} onChange={e => upd({ inflationRate: e.target.value })} style={{ paddingLeft: 18, borderColor: "var(--purple)", fontSize: 12 }} placeholder="3"/>
            </div>
          </div>}
          <SearchBar d={d} setTab={setTab}/>
        </div>
        <div className="page">
          {tab === "overview" && <Overview d={d} budget={budget} prices={prices} inflOn={inflOn} inflRate={inflRate}/>}
          {tab === "budget" && <BudgetTab d={d} upd={upd} budget={budget}/>}
          {tab === "taxes" && <TaxTab d={d} budget={budget} prices={prices}/>}
          {tab === "investments" && <InvestmentsTab d={d} upd={upd} prices={prices} setPrices={setPrices} budget={budget}/>}
          {tab === "networth" && <NetWorthTab d={d} budget={budget} prices={prices} inflOn={inflOn} inflRate={inflRate}/>}
          {tab === "timeline" && <TimelineTab d={d} upd={upd} budget={budget} prices={prices} inflOn={inflOn} inflRate={inflRate}/>}
        </div>
      </div>
    </div>
    <Chatbot d={d} budget={budget} prices={prices}/>
  </>;
}
